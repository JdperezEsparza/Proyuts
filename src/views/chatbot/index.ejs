<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Asistente IA' }) %>
    <style>
        :root {
            --verde-uts: #C3D730;
            --verde-uts-suave: #F0F5CC;
            --verde-uts-oscuro: #7A8A00;
            --gris-claro: #B3B3B3;
            --gris-medio: #878787;
            --fondo: #F5F5F5;
            --oscuro: #1A1A1A;
        }

        body { background-color: var(--fondo); }

        /* === BOTÓN VOLVER === */
        .btn-volver {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 10px;
            padding: 4px 12px;
            font-size: 0.9rem;
            transition: border-color 0.2s, color 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        .btn-volver:hover { border-color: var(--oscuro); color: var(--oscuro); }

        /* === BOTÓN LIMPIAR === */
        .btn-limpiar {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 8px;
            padding: 4px 12px;
            font-size: 0.85rem;
            cursor: pointer;
            transition: border-color 0.2s, color 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .btn-limpiar:hover { border-color: #E53935; color: #E53935; }

        /* === BIENVENIDA BOT === */
        .bienvenida-bot {
            background: var(--oscuro);
            border-left: 5px solid var(--verde-uts);
            border-radius: 16px;
            padding: 16px 20px;
        }
        .bienvenida-bot p { color: #ffffff; }
        .bienvenida-bot small { color: var(--gris-claro); }
        .bienvenida-bot .fw-bold { color: #ffffff; }

        /* === AVATAR BOT === */
        .bot-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: var(--verde-uts);
            display: flex; align-items: center; justify-content: center;
            color: var(--oscuro); font-size: 1rem; flex-shrink: 0;
        }

        /* === SUGERENCIAS === */
        .sugerencia {
            background: var(--bg-card, #fff);
            border: 1px solid #E5E5E5;
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 0.82rem;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
            color: var(--text-primary, #1A1A1A);
        }
        .sugerencia:hover {
            background: var(--verde-uts);
            color: var(--oscuro);
            border-color: var(--verde-uts);
            font-weight: 700;
        }

        /* === CHAT BOX === */
        .chat-box {
            height: 480px; overflow-y: auto; padding: 20px;
            display: flex; flex-direction: column; gap: 12px;
            background: var(--bg-input, #F5F5F5); border-radius: 12px;
        }

        /* === BURBUJAS === */
        .burbuja {
            max-width: 75%; padding: 12px 16px; border-radius: 18px;
            font-size: 0.93rem; line-height: 1.5; word-break: break-word;
        }
        .burbuja.usuario {
            background-color: var(--verde-uts);
            color: var(--oscuro);
            font-weight: 600;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }
        .burbuja.bot {
            background-color: var(--bg-card, #fff);
            color: var(--text-primary, #1A1A1A);
            align-self: flex-start;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.07);
        }
        .hora { font-size: 0.7rem; opacity: 0.6; margin-top: 3px; }

        /* === CARDS CHAT === */
        .card-chat-top {
            border: 1px solid #E5E5E5 !important;
            border-radius: 16px 16px 0 0;
            background: var(--bg-card, #fff);
        }
        .card-chat-bottom {
            border: 1px solid #E5E5E5 !important;
            border-top: 1px solid var(--border-color, #E5E5E5) !important;
            border-radius: 0 0 16px 16px;
            background: var(--bg-card, #fff);
            padding: 12px;
        }

        /* === INPUT MENSAJE === */
        .input-mensaje {
            border-radius: 24px;
            border: 2px solid #E5E5E5;
            padding: 10px 18px;
            font-size: 0.95rem;
            resize: none;
            background: var(--bg-input, #F5F5F5);
            color: var(--text-primary, #1A1A1A);
            transition: border-color 0.2s;
        }
        .input-mensaje:focus {
            border-color: var(--verde-uts);
            box-shadow: none;
            outline: none;
        }

        /* === BOTÓN ENVIAR === */
        .btn-enviar {
            width: 46px; height: 46px; border-radius: 50%;
            background-color: var(--verde-uts);
            border: none; color: var(--oscuro);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; cursor: pointer;
            transition: background 0.2s;
            font-size: 1rem;
        }
        .btn-enviar:hover { background-color: #b0c228; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-md-8">

                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="d-flex align-items-center">
                        <a href="/dashboard" class="btn-volver me-3"><i class="bi bi-arrow-left"></i></a>
                        <h4 class="fw-bold mb-0">
                            <i class="bi bi-stars me-2" style="color:#7c4dff;"></i>Asistente IA ProyUts
                        </h4>
                    </div>
                    <% if (historial.length > 0) { %>
                    <form action="/chatbot/limpiar" method="POST">
                        <button type="submit" class="btn-limpiar">
                            <i class="bi bi-trash"></i>Limpiar
                        </button>
                    </form>
                    <% } %>
                </div>

                <% if (historial.length === 0) { %>
                <div class="bienvenida-bot mb-4">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="bot-avatar"><i class="bi bi-stars"></i></div>
                        <div>
                            <p class="fw-bold mb-0">Asistente ProyUts</p>
                            <small>Powered by Groq AI</small>
                        </div>
                    </div>
                    <p class="mb-0">Hola <%= usuario.nombre %>, soy tu asistente virtual. Puedo ayudarte con dudas sobre tus proyectos, cursos y requisitos de graduación.</p>
                </div>
                <p class="text-muted small mb-2">Preguntas frecuentes:</p>
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="sugerencia" onclick="usarSugerencia(this)">¿Cuántos proyectos necesito para graduarme?</span>
                    <span class="sugerencia" onclick="usarSugerencia(this)">¿En qué cursos puedo obtener proyectos?</span>
                    <span class="sugerencia" onclick="usarSugerencia(this)">¿Cómo registro un proyecto en ProyUts?</span>
                    <span class="sugerencia" onclick="usarSugerencia(this)">Consejos para avanzar más rápido</span>
                </div>
                <% } %>

                <!-- Chat -->
                <div class="card-chat-top">
                    <div class="chat-box" id="chatBox">
                        <% if (historial.length === 0) { %>
                        <div class="text-center text-muted my-auto">
                            <i class="bi bi-chat-dots fs-1 d-block mb-2"></i>
                            <p>Escribe tu primera pregunta abajo</p>
                        </div>
                        <% } else { %>
                            <% historial.forEach(m => { %>
                            <div class="d-flex flex-column <%= m.rol === 'usuario' ? 'align-items-end' : 'align-items-start' %>">
                                <% if (m.rol === 'bot') { %>
                                <div class="d-flex align-items-end gap-2">
                                    <div class="bot-avatar mb-1"><i class="bi bi-stars"></i></div>
                                    <div>
                                        <div class="burbuja bot"><%= m.contenido %></div>
                                        <small class="hora text-muted"><%= m.hora %></small>
                                    </div>
                                </div>
                                <% } else { %>
                                <div class="burbuja usuario"><%= m.contenido %></div>
                                <small class="hora text-muted"><%= m.hora %></small>
                                <% } %>
                            </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>

                <!-- Input -->
                <div class="card-chat-bottom">
                    <form action="/chatbot" method="POST" id="formChat">
                        <div class="d-flex align-items-center gap-2">
                            <textarea name="mensaje" id="inputMensaje" class="form-control input-mensaje"
                                      rows="1" placeholder="Escribe tu pregunta..."
                                      onkeydown="if(event.key==='Enter' && !event.shiftKey){ event.preventDefault(); document.getElementById('formChat').submit(); }"></textarea>
                            <button type="submit" class="btn-enviar">
                                <i class="bi bi-send-fill"></i>
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
    <script>
        const chatBox = document.getElementById('chatBox');
        chatBox.scrollTop = chatBox.scrollHeight;
        function usarSugerencia(el) {
            document.getElementById('inputMensaje').value = el.textContent;
            document.getElementById('formChat').submit();
        }
    </script>
</body>
</html>
