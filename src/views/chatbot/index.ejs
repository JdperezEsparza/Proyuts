<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Asistente IA' }) %>
    <style>
        .chat-box {
            height: 480px; overflow-y: auto; padding: 20px;
            display: flex; flex-direction: column; gap: 12px;
            background: var(--bg-input); border-radius: 12px;
        }
        .burbuja {
            max-width: 75%; padding: 12px 16px; border-radius: 18px;
            font-size: 0.93rem; line-height: 1.5; word-break: break-word;
        }
        .burbuja.usuario {
            background-color: #1a237e; color: white;
            align-self: flex-end; border-bottom-right-radius: 4px;
        }
        .burbuja.bot {
            background-color: var(--bg-card); color: var(--text-primary);
            align-self: flex-start; border-bottom-left-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        .hora { font-size: 0.7rem; opacity: 0.6; margin-top: 3px; }
        .bot-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: linear-gradient(135deg, #1a237e, #7c4dff);
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1rem; flex-shrink: 0;
        }
        .input-mensaje {
            border-radius: 24px; border: 2px solid var(--border-color);
            padding: 10px 18px; font-size: 0.95rem; resize: none;
            background: var(--bg-input); color: var(--text-primary);
        }
        .input-mensaje:focus { border-color: #1a237e; box-shadow: none; }
        .btn-enviar {
            width: 46px; height: 46px; border-radius: 50%;
            background-color: #1a237e; border: none; color: white;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; cursor: pointer;
        }
        .btn-enviar:hover { background-color: #283593; }
        .sugerencia {
            background: var(--bg-card); border: 1px solid var(--border-color);
            border-radius: 20px; padding: 6px 14px; font-size: 0.82rem;
            cursor: pointer; transition: all 0.2s; white-space: nowrap;
            color: var(--text-primary);
        }
        .sugerencia:hover { background: #1a237e; color: white; border-color: #1a237e; }
        .bienvenida-bot {
            background: linear-gradient(135deg, #1a237e, #3949ab);
            color: white; border-radius: 16px; padding: 16px 20px;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="d-flex align-items-center">
                        <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
                        <h4 class="fw-bold mb-0"><i class="bi bi-stars me-2 text-primary"></i>Asistente IA ProyUts</h4>
                    </div>
                    <% if (historial.length > 0) { %>
                    <form action="/chatbot/limpiar" method="POST">
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-trash me-1"></i>Limpiar
                        </button>
                    </form>
                    <% } %>
                </div>
                <% if (historial.length === 0) { %>
                <div class="bienvenida-bot mb-4">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="bot-avatar"><i class="bi bi-stars"></i></div>
                        <div>
                            <p class="fw-bold mb-0">Asistente ProyUts</p>
                            <small class="opacity-75">Powered by Groq AI</small>
                        </div>
                    </div>
                    <p class="mb-0">Hola <%= usuario.nombre %>, soy tu asistente virtual. Puedo ayudarte con dudas sobre tus proyectos, cursos y requisitos de graduación.</p>
                </div>
                <p class="text-muted small mb-2">Preguntas frecuentes:</p>
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="sugerencia" onclick="usarSugerencia(this)">¿Cuántos proyectos necesito para graduarme?</span>
                    <span class="sugerencia" onclick="usarSugerencia(this)">¿En qué cursos puedo obtener proyectos?</span>
                    <span class="sugerencia" onclick="usarSugerencia(this)">¿Cómo registro un proyecto en ProyUts?</span>
                    <span class="sugerencia" onclick="usarSugerencia(this)">Consejos para avanzar más rápido</span>
                </div>
                <% } %>
                <div class="card mb-0" style="border-radius:16px 16px 0 0;">
                    <div class="chat-box" id="chatBox">
                        <% if (historial.length === 0) { %>
                        <div class="text-center text-muted my-auto">
                            <i class="bi bi-chat-dots fs-1 d-block mb-2"></i>
                            <p>Escribe tu primera pregunta abajo</p>
                        </div>
                        <% } else { %>
                            <% historial.forEach(m => { %>
                            <div class="d-flex flex-column <%= m.rol === 'usuario' ? 'align-items-end' : 'align-items-start' %>">
                                <% if (m.rol === 'bot') { %>
                                <div class="d-flex align-items-end gap-2">
                                    <div class="bot-avatar mb-1"><i class="bi bi-stars"></i></div>
                                    <div>
                                        <div class="burbuja bot"><%= m.contenido %></div>
                                        <small class="hora text-muted"><%= m.hora %></small>
                                    </div>
                                </div>
                                <% } else { %>
                                <div class="burbuja usuario"><%= m.contenido %></div>
                                <small class="hora text-muted"><%= m.hora %></small>
                                <% } %>
                            </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
                <div class="card p-3" style="border-radius:0 0 16px 16px; border-top:1px solid var(--border-color);">
                    <form action="/chatbot" method="POST" id="formChat">
                        <div class="d-flex align-items-center gap-2">
                            <textarea name="mensaje" id="inputMensaje" class="form-control input-mensaje"
                                      rows="1" placeholder="Escribe tu pregunta..."
                                      onkeydown="if(event.key==='Enter' && !event.shiftKey){ event.preventDefault(); document.getElementById('formChat').submit(); }"></textarea>
                            <button type="submit" class="btn-enviar"><i class="bi bi-send-fill"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
    <script>
        const chatBox = document.getElementById('chatBox');
        chatBox.scrollTop = chatBox.scrollHeight;
        function usarSugerencia(el) {
            document.getElementById('inputMensaje').value = el.textContent;
            document.getElementById('formChat').submit();
        }
    </script>
</body>
</html>
