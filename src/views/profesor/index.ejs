<!DOCTYPE html>
<html lang="es">

<head>
    <%- include('../partials/head', { titulo: 'Panel Profesor' }) %>
        <style>
            .stat-card {
                border-radius: 16px;
                border: none;
                box-shadow: var(--shadow);
                padding: 20px;
                background: var(--bg-card);
                text-align: center;
            }

            .proyecto-card {
                border: none;
                border-radius: 12px;
                box-shadow: var(--shadow);
                transition: transform 0.2s;
            }

            .proyecto-card:hover {
                transform: translateY(-3px);
            }

            .estado-enviado {
                border-left: 5px solid #1a237e;
            }

            .estado-terminado {
                border-left: 5px solid #2e7d32;
            }

            .estado-rechazado {
                border-left: 5px solid #c62828;
            }

            .estado-en_progreso {
                border-left: 5px solid #e65100;
            }

            .btn-primary {
                background-color: #1a237e;
                border-color: #1a237e;
            }

            .btn-primary:hover {
                background-color: #283593;
                border-color: #283593;
            }
        </style>
</head>

<body>
    <%- include('../partials/navbar') %>
        <div class="container py-4">

            <!-- Encabezado -->
            <div class="d-flex align-items-center mb-4">
                <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
                <h4 class="fw-bold mb-0">
                    <i class="bi bi-person-workspace me-2 text-primary"></i>Panel del Profesor
                </h4>
            </div>

            <!-- Alertas -->
            <% if (typeof query !=='undefined' && query && query.msg==='aprobado' ) { %>
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle me-2"></i>Proyecto aprobado correctamente.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <% } else if (typeof query !=='undefined' && query && query.msg==='rechazado' ) { %>
                    <div class="alert alert-warning alert-dismissible fade show">
                        <i class="bi bi-x-circle me-2"></i>Proyecto rechazado con comentario.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                        <!-- Estadísticas -->
                        <div class="row g-3 mb-4">
                            <div class="col-6 col-md-3">
                                <div class="stat-card">
                                    <h3 class="fw-bold text-primary mb-0">
                                        <%= enviados %>
                                    </h3>
                                    <small class="text-muted">Pendientes de revisión</small>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-card">
                                    <h3 class="fw-bold text-success mb-0">
                                        <%= terminados %>
                                    </h3>
                                    <small class="text-muted">Aprobados</small>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-card">
                                    <h3 class="fw-bold text-danger mb-0">
                                        <%= rechazados %>
                                    </h3>
                                    <small class="text-muted">Rechazados</small>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-card">
                                    <h3 class="fw-bold text-warning mb-0">
                                        <%= enProgreso %>
                                    </h3>
                                    <small class="text-muted">En progreso</small>
                                </div>
                            </div>
                        </div>

                        <!-- Filtros -->
                        <div class="d-flex gap-2 mb-3 flex-wrap">
                            <a href="/profesor"
                                class="btn btn-sm <%= filtro === 'todos' ? 'btn-primary' : 'btn-outline-secondary' %>">
                                Todos (<%= proyectos.length %>)
                            </a>
                            <a href="/profesor?filtro=enviado"
                                class="btn btn-sm <%= filtro === 'enviado' ? 'btn-primary' : 'btn-outline-primary' %>">
                                Pendientes (<%= enviados %>)
                            </a>
                            <a href="/profesor?filtro=terminado"
                                class="btn btn-sm <%= filtro === 'terminado' ? 'btn-success' : 'btn-outline-success' %>">
                                Aprobados (<%= terminados %>)
                            </a>
                            <a href="/profesor?filtro=rechazado"
                                class="btn btn-sm <%= filtro === 'rechazado' ? 'btn-danger' : 'btn-outline-danger' %>">
                                Rechazados (<%= rechazados %>)
                            </a>
                            <a href="/profesor?filtro=en_progreso"
                                class="btn btn-sm <%= filtro === 'en_progreso' ? 'btn-warning' : 'btn-outline-warning' %>">
                                En progreso (<%= enProgreso %>)
                            </a>
                        </div>

                        <!-- Lista de proyectos -->
                        <% const proyectosFiltrados=filtro==='todos' ? proyectos : proyectos.filter(p=> p.estado ===
                            filtro); %>

                            <% if (proyectosFiltrados.length===0) { %>
                                <div class="card p-5 text-center"
                                    style="border:none; border-radius:16px; box-shadow:var(--shadow);">
                                    <i class="bi bi-folder2-open fs-1 text-muted d-block mb-3"></i>
                                    <h5 class="text-muted">No hay proyectos en esta categoría</h5>
                                </div>
                                <% } else { %>
                                    <% proyectosFiltrados.forEach(p=> { %>
                                        <div class="proyecto-card card p-3 mb-3 estado-<%= p.estado %>">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div class="flex-grow-1">
                                                    <!-- Estado y título -->
                                                    <div class="d-flex align-items-center gap-2 mb-1">
                                                        <h6 class="fw-bold mb-0">
                                                            <%= p.titulo %>
                                                        </h6>
                                                        <span
                                                            class="badge <%= p.estado === 'enviado' ? 'bg-primary' : p.estado === 'terminado' ? 'bg-success' : p.estado === 'rechazado' ? 'bg-danger' : 'bg-warning text-dark' %>">
                                                            <%= p.estado==='enviado' ? 'Pendiente revisión' :
                                                                p.estado==='terminado' ? 'Aprobado' :
                                                                p.estado==='rechazado' ? 'Rechazado' : 'En progreso' %>
                                                        </span>
                                                    </div>

                                                    <!-- Estudiante -->
                                                    <p class="text-muted small mb-1">
                                                        <i class="bi bi-person me-1"></i>
                                                        <strong>
                                                            <%= p.nombreEstudiante %>
                                                                <%= p.apellidoEstudiante %>
                                                        </strong>
                                                        · <%= p.codigoEstudiante %>
                                                    </p>

                                                    <!-- Descripción -->
                                                    <% if (p.descripcion) { %>
                                                        <p class="text-muted small mb-1">
                                                            <%= p.descripcion %>
                                                        </p>
                                                        <% } %>

                                                            <!-- Info -->
                                                            <div class="d-flex gap-3">
                                                                <small class="text-muted"><i
                                                                        class="bi bi-book me-1"></i>
                                                                    <%= p.nombre_curso || 'Sin curso' %>
                                                                </small>
                                                                <small class="text-muted"><i
                                                                        class="bi bi-calendar me-1"></i>
                                                                    <%= new
                                                                        Date(p.fechaRealizacion).toLocaleDateString('es-CO')
                                                                        %>
                                                                </small>
                                                                <small class="text-muted"><i
                                                                        class="bi bi-bookmark me-1"></i>Semestre <%=
                                                                        p.semestre %></small>
                                                            </div>

                                                            <!-- Comentario de rechazo -->
                                                            <% if (p.comentarioProfesor) { %>
                                                                <div
                                                                    class="alert alert-warning py-1 px-2 mt-2 mb-0 small">
                                                                    <i class="bi bi-chat-left-text me-1"></i>
                                                                    <%= p.comentarioProfesor %>
                                                                </div>
                                                                <% } %>
                                                </div>

                                                <!-- Acciones solo para proyectos enviados -->
                                                <% if (p.estado==='enviado' ) { %>
                                                    <div class="d-flex flex-column gap-2 ms-3">
                                                        <!-- Aprobar -->
                                                        <form action="/profesor/proyectos/<%= p.id %>/aprobar"
                                                            method="POST"
                                                            onsubmit="return confirm('¿Aprobar este proyecto?')">
                                                            <button type="submit" class="btn btn-success btn-sm w-100">
                                                                <i class="bi bi-check-circle me-1"></i>Aprobar
                                                            </button>
                                                        </form>
                                                        <!-- Rechazar -->
                                                        <button type="button" class="btn btn-outline-danger btn-sm"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#rechazo-<%= p.id %>">
                                                            <i class="bi bi-x-circle me-1"></i>Rechazar
                                                        </button>
                                                        <div class="collapse" id="rechazo-<%= p.id %>">
                                                            <form action="/profesor/proyectos/<%= p.id %>/rechazar"
                                                                method="POST" class="mt-2">
                                                                <textarea name="comentario"
                                                                    class="form-control form-control-sm mb-2" rows="2"
                                                                    placeholder="Motivo del rechazo..."
                                                                    required></textarea>
                                                                <button type="submit"
                                                                    class="btn btn-danger btn-sm w-100">
                                                                    Confirmar rechazo
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } %>

        </div>
        <%- include('../partials/scripts') %>
</body>

</html>