<%# ============================================
    ProyUts - Cursos Disponibles
    src/views/cursos/index.ejs
    ============================================ %>
<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Cursos' }) %>
    <style>
        .curso-card {
            border: none; border-radius: 12px;
            border-left: 5px solid #1a237e;
            box-shadow: var(--shadow); transition: transform 0.2s;
        }
        .curso-card:hover { transform: translateY(-3px); }
        .curso-card.inscrito { border-left-color: #2e7d32; }
        .curso-card.sin-profesor { border-left-color: #878787; opacity: 0.75; }
        .curso-card.lleno { border-left-color: #c62828; opacity: 0.75; }
        .btn-primary { background-color: #1a237e; border-color: #1a237e; }
        .btn-primary:hover { background-color: #283593; border-color: #283593; }
        .capacidad-bar { height: 6px; border-radius: 4px; background: #e0e0e0; overflow: hidden; }
        .capacidad-fill { height: 100%; border-radius: 4px; transition: width 0.3s; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <!-- Encabezado -->
        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-book me-2 text-primary"></i>Cursos Disponibles
            </h4>
        </div>

        <!-- Alertas -->
        <% if (mensaje === 'inscrito') { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>Te inscribiste al curso exitosamente.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } else if (mensaje === 'baja') { %>
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-info-circle me-2"></i>Te diste de baja del curso.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } else if (mensaje === 'sin-profesor') { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-2"></i>No puedes inscribirte a este curso porque aún no tiene un profesor asignado.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } else if (mensaje === 'lleno') { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-people me-2"></i>Este curso ya alcanzó su capacidad máxima de estudiantes.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>

        <!-- Resumen inscritos -->
        <div class="card p-3 mb-4" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="fw-bold mb-0">Mis cursos inscritos</h6>
                    <small class="text-muted">Cursos en los que estás actualmente inscrito</small>
                </div>
                <span class="badge bg-primary fs-6"><%= inscritos.length %> cursos</span>
            </div>
            <% if (inscritos.length > 0) { %>
            <div class="mt-2 d-flex flex-wrap gap-2">
                <% inscritos.forEach(c => { %>
                <span class="badge bg-success"><%= c.nombre %></span>
                <% }) %>
            </div>
            <% } %>
        </div>

        <!-- Filtros -->
        <div class="d-flex gap-2 mb-3 flex-wrap">
            <button class="btn btn-sm btn-primary" onclick="filtrar('todos')">Todos</button>
            <button class="btn btn-sm btn-outline-success" onclick="filtrar('inscrito')">Inscritos</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="filtrar('no-inscrito')">No inscritos</button>
        </div>

        <!-- Lista de cursos -->
        <% if (cursos.length === 0) { %>
        <div class="card p-5 text-center" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
            <i class="bi bi-book fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">No hay cursos disponibles</h5>
        </div>
        <% } else { %>
            <% cursos.forEach(c => {
                const porcentaje = Math.round((c.inscritos / c.capacidadMaxima) * 100);
                const lleno = c.inscritos >= c.capacidadMaxima;
                const sinProfesor = !c.tieneProfesor || c.tieneProfesor == 0;
                const claseExtra = c.inscrito ? 'inscrito' : sinProfesor ? 'sin-profesor' : lleno ? 'lleno' : '';
            %>
            <div class="curso-card card p-3 mb-3 <%= claseExtra %>"
                 data-estado="<%= c.inscrito ? 'inscrito' : 'no-inscrito' %>">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">

                        <!-- Nombre y badges -->
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <h6 class="fw-bold mb-0"><%= c.nombre %></h6>
                            <% if (c.inscrito) { %>
                            <span class="badge bg-success">Inscrito</span>
                            <% } %>
                            <% if (sinProfesor) { %>
                            <span class="badge bg-secondary">Sin profesor</span>
                            <% } %>
                            <% if (lleno && !c.inscrito) { %>
                            <span class="badge bg-danger">Cupo lleno</span>
                            <% } %>
                        </div>

                        <!-- Descripción -->
                        <% if (c.descripcion) { %>
                        <p class="text-muted small mb-2"><%= c.descripcion %></p>
                        <% } %>

                        <!-- Info -->
                        <div class="d-flex gap-3 flex-wrap mb-2">
                            <small class="text-muted">
                                <i class="bi bi-bookmark me-1"></i>Semestre <%= c.semestre %>
                            </small>
                            <small class="text-muted">
                                <i class="bi bi-star me-1"></i><%= c.creditos %> créditos
                            </small>
                            <small class="text-muted">
                                <i class="bi bi-people me-1"></i><%= c.inscritos %> / <%= c.capacidadMaxima %> estudiantes
                            </small>
                            <% if (c.nombreProfesor) { %>
                            <small class="text-muted">
                                <i class="bi bi-person-workspace me-1"></i><%= c.nombreProfesor %>
                            </small>
                            <% } %>
                        </div>

                        <!-- Barra de capacidad -->
                        <div class="capacidad-bar" style="max-width: 200px;">
                            <div class="capacidad-fill"
                                 style="width:<%= porcentaje %>%;
                                        background-color: <%= porcentaje >= 100 ? '#c62828' : porcentaje >= 75 ? '#f57c00' : '#2e7d32' %>;">
                            </div>
                        </div>
                        <small class="text-muted"><%= porcentaje %>% de capacidad usado</small>

                    </div>

                    <!-- Botón de acción -->
                    <div class="ms-3 mt-1">
                        <% if (c.inscrito) { %>
                        <form action="/cursos/<%= c.id %>/baja" method="POST"
                              onsubmit="return confirm('¿Seguro que quieres darte de baja?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-x-circle me-1"></i>Dar de baja
                            </button>
                        </form>
                        <% } else if (sinProfesor) { %>
                        <button class="btn btn-secondary btn-sm" disabled title="Sin profesor asignado">
                            <i class="bi bi-lock me-1"></i>No disponible
                        </button>
                        <% } else if (lleno) { %>
                        <button class="btn btn-danger btn-sm" disabled title="Cupo lleno">
                            <i class="bi bi-people me-1"></i>Cupo lleno
                        </button>
                        <% } else { %>
                        <form action="/cursos/<%= c.id %>/inscribir" method="POST">
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus-circle me-1"></i>Inscribirse
                            </button>
                        </form>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }) %>
        <% } %>

    </div>
    <%- include('../partials/scripts') %>
    <script>
        function filtrar(tipo) {
            document.querySelectorAll('[data-estado]').forEach(t => {
                t.style.display = (tipo === 'todos' || t.dataset.estado === tipo) ? 'block' : 'none';
            });
        }
    </script>
</body>
</html>
