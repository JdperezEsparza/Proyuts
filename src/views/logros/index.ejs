<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Mis Logros' }) %>
    <style>
        :root {
            --verde-uts: #C3D730;
            --verde-uts-suave: #F0F5CC;
            --verde-uts-oscuro: #7A8A00;
            --gris-claro: #B3B3B3;
            --gris-medio: #878787;
            --fondo: #F5F5F5;
            --oscuro: #1A1A1A;
        }

        body { background-color: var(--fondo); }

        /* === BOTÓN VOLVER === */
        .btn-volver {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 10px;
            padding: 4px 12px;
            font-size: 0.9rem;
            transition: border-color 0.2s, color 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        .btn-volver:hover { border-color: var(--oscuro); color: var(--oscuro); }

        /* === RESUMEN CARD (antes gradiente azul) === */
        .resumen-card {
            background: var(--oscuro);
            border-left: 5px solid var(--verde-uts);
            border-radius: 16px;
            padding: 20px 24px;
        }
        .resumen-card p  { color: var(--gris-claro); }
        .resumen-card h3 { color: #ffffff; }
        .resumen-card .icono-fondo {
            font-size: 3rem;
            opacity: 0.15;
            color: var(--verde-uts);
        }

        /* === BARRA DE PROGRESO DEL RESUMEN === */
        .progreso-logro {
            height: 8px;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            margin-top: 10px;
            overflow: hidden;
        }
        .progreso-logro-bar {
            height: 100%;
            border-radius: 8px;
            background: var(--verde-uts);
            transition: width 0.5s ease;
        }

        /* === LOGRO CARDS === */
        .logro-card {
            border-radius: 16px;
            border: 1px solid #E5E5E5;
            padding: 24px 16px;
            text-align: center;
            transition: transform 0.2s, box-shadow 0.2s;
            background: var(--bg-card, #fff);
        }
        .logro-card.obtenido {
            border-color: var(--verde-uts);
            border-width: 2px;
            background: var(--verde-uts-suave);
            box-shadow: 0 4px 20px rgba(195,215,48,0.15);
        }
        .logro-card.pendiente { opacity: 0.5; filter: grayscale(50%); }
        .logro-card:hover { transform: translateY(-4px); }

        /* === BARRA DE PROGRESO EN CARDS === */
        .progreso-card {
            height: 8px;
            border-radius: 8px;
            background: #E5E5E5;
            margin-top: 10px;
            overflow: hidden;
        }
        .progreso-card-bar {
            height: 100%;
            border-radius: 8px;
            background: var(--verde-uts);
            transition: width 0.5s ease;
        }

        /* === BADGES === */
        .badge-pts-obtenido {
            background: var(--verde-uts);
            color: var(--oscuro);
            font-weight: 700;
            font-size: 0.8rem;
            border-radius: 8px;
            padding: 3px 10px;
        }
        .badge-pts-pendiente {
            background: #EEEEEE;
            color: var(--gris-medio);
            font-weight: 600;
            font-size: 0.8rem;
            border-radius: 8px;
            padding: 3px 10px;
        }

        /* === TEXTO OBTENIDO === */
        .texto-obtenido {
            color: var(--verde-uts-oscuro);
            font-weight: 700;
            font-size: 0.85rem;
        }

        /* === CARD VACÍO === */
        .card-vacio {
            border: 1px solid #E5E5E5 !important;
            border-radius: 16px;
            background: #fff;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn-volver me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-award-fill me-2" style="color:#e91e63;"></i>Mis Logros
            </h4>
        </div>

        <!-- Resumen -->
        <div class="resumen-card mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-0 small">Logros obtenidos</p>
                    <h3 class="fw-bold mb-0"><%= obtenidos %> / <%= logros.length %></h3>
                </div>
                <div class="text-end">
                    <p class="mb-0 small">Proyectos terminados</p>
                    <h3 class="fw-bold mb-0"><%= terminados %></h3>
                </div>
                <i class="bi bi-award-fill icono-fondo"></i>
            </div>
            <div class="mt-3">
                <div class="d-flex justify-content-between mb-1">
                    <small style="color:var(--gris-claro);">Progreso de logros</small>
                    <small style="color:var(--gris-claro);"><%= Math.round((obtenidos/logros.length)*100) %>%</small>
                </div>
                <div class="progreso-logro">
                    <div class="progreso-logro-bar"
                         style="width:<%= Math.round((obtenidos/logros.length)*100) %>%;">
                    </div>
                </div>
            </div>
        </div>

        <!-- Grid de logros -->
        <% if (logros.length === 0) { %>
        <div class="card-vacio card p-5 text-center">
            <i class="bi bi-award fs-1 d-block mb-3" style="color:var(--gris-medio);"></i>
            <h5 class="text-muted">No hay logros disponibles aún</h5>
        </div>
        <% } else { %>
        <div class="row g-3">
            <% logros.forEach(l => { %>
            <div class="col-6 col-md-4">
                <div class="logro-card <%= l.fecha_obtenido ? 'obtenido' : 'pendiente' %>">
                    <div style="font-size:2.8rem; margin-bottom:10px;">
                        <% if (l.fecha_obtenido) { %>
                        <i class="bi bi-award-fill" style="color:var(--verde-uts-oscuro);"></i>
                        <% } else { %>
                        <i class="bi bi-award" style="color:#9e9e9e;"></i>
                        <% } %>
                    </div>
                    <h6 class="fw-bold mb-1"><%= l.nombre %></h6>
                    <small class="text-muted"><%= l.descripcion %></small>
                    <div class="mt-2">
                        <span class="<%= l.fecha_obtenido ? 'badge-pts-obtenido' : 'badge-pts-pendiente' %>">
                            <%= l.puntos_otorgados %> pts
                        </span>
                    </div>
                    <% if (!l.fecha_obtenido) { %>
                    <div class="progreso-card">
                        <div class="progreso-card-bar"
                             style="width:<%= Math.min(100, Math.round((terminados/l.proyectos_requeridos)*100)) %>%;">
                        </div>
                    </div>
                    <small class="text-muted d-block mt-1">
                        <%= terminados %> / <%= l.proyectos_requeridos %> proyectos
                    </small>
                    <% } else { %>
                    <small class="texto-obtenido d-block mt-2">
                        <i class="bi bi-check-circle me-1"></i>Obtenido
                    </small>
                    <small class="text-muted">
                        <%= new Date(l.fecha_obtenido).toLocaleDateString('es-CO', { year:'numeric', month:'long', day:'numeric' }) %>
                    </small>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
        <% } %>

    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
