<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Mis Logros' }) %>
    <style>
        .logro-card {
            border-radius: 16px; border: 2px solid var(--border-color);
            padding: 24px 16px; text-align: center; transition: transform 0.2s;
            background: var(--bg-card);
        }
        .logro-card.obtenido {
            border-color: #1a237e;
            background: linear-gradient(135deg, var(--bg-hover), var(--bg-card));
            box-shadow: 0 4px 20px rgba(26,35,126,0.12);
        }
        .logro-card.pendiente { opacity: 0.5; filter: grayscale(50%); }
        .logro-card:hover { transform: translateY(-4px); }
        .progreso-logro {
            height: 8px; border-radius: 8px; background: var(--border-color);
            margin-top: 10px; overflow: hidden;
        }
        .progreso-logro-bar {
            height: 100%; border-radius: 8px;
            background: linear-gradient(90deg, #1a237e, #3949ab);
            transition: width 0.5s ease;
        }
        .resumen-card {
            background: linear-gradient(135deg, #1a237e, #3949ab);
            color: white; border-radius: 16px; padding: 20px 24px;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">
        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-award-fill me-2" style="color:#e91e63;"></i>Mis Logros
            </h4>
        </div>
        <div class="resumen-card mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-0 opacity-75 small">Logros obtenidos</p>
                    <h3 class="fw-bold mb-0"><%= obtenidos %> / <%= logros.length %></h3>
                </div>
                <div class="text-end">
                    <p class="mb-0 opacity-75 small">Proyectos terminados</p>
                    <h3 class="fw-bold mb-0"><%= terminados %></h3>
                </div>
                <i class="bi bi-award-fill" style="font-size:3rem; opacity:0.3;"></i>
            </div>
            <div class="mt-3">
                <div class="d-flex justify-content-between mb-1">
                    <small class="opacity-75">Progreso de logros</small>
                    <small class="opacity-75"><%= Math.round((obtenidos/logros.length)*100) %>%</small>
                </div>
                <div class="progreso-logro" style="background:rgba(255,255,255,0.2);">
                    <div class="progreso-logro-bar"
                         style="width:<%= Math.round((obtenidos/logros.length)*100) %>%; background:white;">
                    </div>
                </div>
            </div>
        </div>
        <div class="row g-3">
            <% logros.forEach(l => { %>
            <div class="col-6 col-md-4">
                <div class="logro-card <%= l.fecha_obtenido ? 'obtenido' : 'pendiente' %>">
                    <div style="font-size:2.8rem; margin-bottom:10px;">
                        <% if (l.fecha_obtenido) { %>
                        <i class="bi bi-award-fill" style="color:#1a237e;"></i>
                        <% } else { %>
                        <i class="bi bi-award" style="color:#9e9e9e;"></i>
                        <% } %>
                    </div>
                    <h6 class="fw-bold mb-1"><%= l.nombre %></h6>
                    <small class="text-muted"><%= l.descripcion %></small>
                    <div class="mt-2">
                        <span class="badge <%= l.fecha_obtenido ? 'bg-primary' : 'bg-secondary' %>">
                            <%= l.puntos_otorgados %> pts
                        </span>
                    </div>
                    <% if (!l.fecha_obtenido) { %>
                    <div class="progreso-logro mt-3">
                        <div class="progreso-logro-bar"
                             style="width:<%= Math.min(100, Math.round((terminados/l.proyectos_requeridos)*100)) %>%;">
                        </div>
                    </div>
                    <small class="text-muted d-block mt-1">
                        <%= terminados %> / <%= l.proyectos_requeridos %> proyectos
                    </small>
                    <% } else { %>
                    <small class="text-success d-block mt-2 fw-bold">
                        <i class="bi bi-check-circle me-1"></i>Obtenido
                    </small>
                    <small class="text-muted">
                        <%= new Date(l.fecha_obtenido).toLocaleDateString('es-CO', { year:'numeric', month:'long', day:'numeric' }) %>
                    </small>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
        <% if (logros.length === 0) { %>
        <div class="card p-5 text-center">
            <i class="bi bi-award fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">No hay logros disponibles aún</h5>
        </div>
        <% } %>
    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
