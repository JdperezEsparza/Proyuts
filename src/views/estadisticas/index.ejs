<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Estadísticas' }) %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --verde-uts: #C3D730;
            --verde-uts-suave: #F0F5CC;
            --verde-uts-oscuro: #7A8A00;
            --gris-claro: #B3B3B3;
            --gris-medio: #878787;
            --fondo: #F5F5F5;
            --oscuro: #1A1A1A;
        }

        body { background-color: var(--fondo); }

        /* === BOTÓN VOLVER === */
        .btn-volver {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 10px;
            padding: 4px 12px;
            font-size: 0.9rem;
            transition: border-color 0.2s, color 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        .btn-volver:hover { border-color: var(--oscuro); color: var(--oscuro); }

        /* === STAT CARDS === */
        .stat-card {
            border-radius: 16px;
            border: 1px solid #E5E5E5 !important;
            box-shadow: var(--shadow);
            padding: 20px;
            text-align: center;
            background: var(--bg-card, #fff);
        }
        .stat-numero { font-size: 2.2rem; font-weight: 800; line-height: 1; }
        .stat-num-total    { color: var(--verde-uts-oscuro); }
        .stat-num-terminado { color: #2e7d32; }
        .stat-num-faltan   { color: #E53935; }
        .stat-num-progreso { color: var(--verde-uts-oscuro); }

        /* === CARD PROGRESO === */
        .card {
            border: 1px solid #E5E5E5 !important;
            border-radius: 16px;
            background: var(--bg-card, #fff);
        }
        .progress-bar-uts {
            background-color: var(--verde-uts) !important;
            border-radius: 10px;
        }
        .texto-graduado {
            color: var(--verde-uts-oscuro);
            font-weight: 700;
            font-size: 0.85rem;
        }

        /* === PROMEDIO CARDS === */
        .promedio-card {
            border-radius: 12px;
            border: 1px solid #E5E5E5;
            border-left: 5px solid var(--verde-uts) !important;
            padding: 14px 18px;
            background: var(--bg-card, #fff);
            box-shadow: var(--shadow);
        }
        .promedio-num { color: var(--verde-uts-oscuro); }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn-volver me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-bar-chart-line me-2" style="color:var(--verde-uts-oscuro);"></i>Estadísticas de Avance
            </h4>
        </div>

        <!-- Stat cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-numero stat-num-total"><%= total %></div>
                    <small class="text-muted">Total proyectos</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-numero stat-num-terminado"><%= terminados %></div>
                    <small class="text-muted">Terminados</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-numero stat-num-faltan"><%= faltan %></div>
                    <small class="text-muted">Faltan para graduarse</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-numero stat-num-progreso"><%= Math.round((terminados/52)*100) %>%</div>
                    <small class="text-muted">Progreso total</small>
                </div>
            </div>
        </div>

        <!-- Barra de progreso -->
        <div class="card p-3 mb-4">
            <div class="d-flex justify-content-between mb-2">
                <span class="fw-bold">Progreso hacia la graduación</span>
                <span class="text-muted"><%= terminados %> / 52</span>
            </div>
            <div class="progress" style="height:16px; border-radius:10px; background:#EEEEEE;">
                <div class="progress-bar-uts progress-bar" role="progressbar"
                     style="width:<%= Math.min(100,(terminados/52)*100) %>%;">
                </div>
            </div>
            <% if (fechaEstimada === 'ya') { %>
            <small class="texto-graduado mt-2 d-block">
                <i class="bi bi-check-circle me-1"></i>Ya cumpliste el requisito de graduación.
            </small>
            <% } else if (fechaEstimada) { %>
            <small class="text-muted mt-2 d-block">
                <i class="bi bi-calendar me-1"></i>
                Estimado de graduación: <strong><%= fechaEstimada.toLocaleDateString('es-CO', { year:'numeric', month:'long', day:'numeric' }) %></strong>
            </small>
            <% } else { %>
            <small class="text-muted mt-2 d-block">
                <i class="bi bi-info-circle me-1"></i>Registra proyectos terminados para estimar tu fecha de graduación.
            </small>
            <% } %>
        </div>

        <!-- Promedios -->
        <h6 class="fw-bold mb-3">Promedios de proyectos terminados</h6>
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="promedio-card">
                    <p class="text-muted small mb-0">Por semana</p>
                    <h4 class="fw-bold promedio-num mb-0"><%= promedioPorSemana %></h4>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="promedio-card">
                    <p class="text-muted small mb-0">Por mes</p>
                    <h4 class="fw-bold promedio-num mb-0"><%= promedioPorMes %></h4>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="promedio-card">
                    <p class="text-muted small mb-0">Por semestre</p>
                    <h4 class="fw-bold promedio-num mb-0"><%= promedioPorSemestre %></h4>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="promedio-card">
                    <p class="text-muted small mb-0">Por año</p>
                    <h4 class="fw-bold promedio-num mb-0"><%= promedioPorAnyo %></h4>
                </div>
            </div>
        </div>

        <!-- Gráficas -->
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Proyectos por semestre</h6>
                    <% if (porSemestre.length === 0) { %>
                    <p class="text-muted text-center py-4">Sin datos aún</p>
                    <% } else { %>
                    <canvas id="graficaSemestre"></canvas>
                    <% } %>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Proyectos por mes</h6>
                    <% if (porMes.length === 0) { %>
                    <p class="text-muted text-center py-4">Sin datos aún</p>
                    <% } else { %>
                    <canvas id="graficaMes"></canvas>
                    <% } %>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Estado de proyectos</h6>
                    <div style="max-width:260px; margin:0 auto;">
                        <canvas id="graficaEstado"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script>
        var datosSemestre       = <%- JSON.stringify(porSemestre) %>;
        var datosMes            = <%- JSON.stringify(porMes) %>;
        var totalProyectos      = <%= total %>;
        var terminadosProyectos = <%= terminados %>;
        var faltanProyectos     = <%= faltan %>;
    </script>
    <%- include('../partials/scripts') %>
    <script>
        const meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

        if (datosSemestre.length > 0) {
            new Chart(document.getElementById('graficaSemestre'), {
                type: 'bar',
                data: {
                    labels: datosSemestre.map(s => 'Sem ' + s.semestre + ' - ' + s.anio),
                    datasets: [
                        { label: 'Terminados', data: datosSemestre.map(s => s.terminados), backgroundColor: '#C3D730' },
                        { label: 'En progreso', data: datosSemestre.map(s => s.total - s.terminados), backgroundColor: '#F57C00' }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'bottom' } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });
        }

        if (datosMes.length > 0) {
            new Chart(document.getElementById('graficaMes'), {
                type: 'line',
                data: {
                    labels: datosMes.map(m => meses[m.mes - 1] + ' ' + m.anio),
                    datasets: [
                        {
                            label: 'Terminados',
                            data: datosMes.map(m => m.terminados),
                            borderColor: '#C3D730',
                            backgroundColor: 'rgba(195,215,48,0.12)',
                            fill: true,
                            tension: 0.4
                        },
                        {
                            label: 'Total',
                            data: datosMes.map(m => m.total),
                            borderColor: '#9e9e9e',
                            borderDash: [5,5],
                            fill: false,
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'bottom' } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });
        }

        new Chart(document.getElementById('graficaEstado'), {
            type: 'doughnut',
            data: {
                labels: ['Terminados', 'En progreso', 'Faltan'],
                datasets: [{
                    data: [terminadosProyectos, totalProyectos - terminadosProyectos, faltanProyectos],
                    backgroundColor: ['#C3D730', '#F57C00', '#E0E0E0'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    </script>
</body>
</html>
