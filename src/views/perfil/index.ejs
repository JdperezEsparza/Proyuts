<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Mi Perfil' }) %>
    <style>
        .avatar {
            width: 90px; height: 90px; border-radius: 50%;
            background: linear-gradient(135deg, #1a237e, #3949ab);
            display: flex; align-items: center; justify-content: center;
            font-size: 2.2rem; color: white; font-weight: 800;
        }
        .stat-box { border-radius: 12px; padding: 16px; text-align: center; }
        .logro-card {
            border-radius: 12px; border: 2px solid var(--border-color);
            padding: 12px; text-align: center; transition: transform 0.2s;
            background: var(--bg-card);
        }
        .logro-card.obtenido { border-color: #1a237e; background-color: var(--bg-hover); }
        .logro-card.pendiente { opacity: 0.45; }
        .logro-card:hover { transform: translateY(-3px); }
        .btn-primary { background-color: #1a237e; border-color: #1a237e; }
        .btn-primary:hover { background-color: #283593; border-color: #283593; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">
        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0"><i class="bi bi-person-circle me-2 text-primary"></i>Mi Perfil</h4>
        </div>
        <% if (mensaje === 'actualizado') { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>Perfil actualizado correctamente.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card p-4 text-center mb-4">
                    <div class="avatar mx-auto mb-3">
                        <%= usuarioPerfil.nombre.charAt(0).toUpperCase() %><%= usuarioPerfil.apellido.charAt(0).toUpperCase() %>
                    </div>
                    <h5 class="fw-bold mb-0"><%= usuarioPerfil.getNombreCompleto() %></h5>
                    <p class="text-muted small mb-2"><%= usuarioPerfil.email %></p>
                    <span class="badge bg-primary"><%= usuarioPerfil.programa %></span>
                    <hr>
                    <div class="d-flex justify-content-around">
                        <div>
                            <h5 class="fw-bold text-primary mb-0"><%= usuarioPerfil.puntos %></h5>
                            <small class="text-muted">Puntos</small>
                        </div>
                        <div>
                            <h5 class="fw-bold text-success mb-0"><%= terminados %></h5>
                            <small class="text-muted">Terminados</small>
                        </div>
                        <div>
                            <h5 class="fw-bold text-danger mb-0"><%= faltan %></h5>
                            <small class="text-muted">Faltan</small>
                        </div>
                    </div>
                </div>
                <div class="card p-3">
                    <h6 class="fw-bold mb-3">Resumen</h6>
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="stat-box bg-light">
                                <h5 class="fw-bold text-primary mb-0"><%= total %></h5>
                                <small class="text-muted">Total</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-box bg-light">
                                <h5 class="fw-bold text-success mb-0"><%= terminados %></h5>
                                <small class="text-muted">Terminados</small>
                            </div>
                        </div>
                        <div class="col-12 mt-2">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="fw-bold">Progreso</small>
                                <small class="text-muted"><%= terminados %>/52</small>
                            </div>
                            <div class="progress" style="height:10px; border-radius:8px;">
                                <div class="progress-bar bg-success"
                                     style="width:<%= Math.min(100,(terminados/52)*100) %>%; border-radius:8px;">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card p-4 mb-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-pencil me-2"></i>Editar información</h6>
                    <form action="/perfil" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nombre</label>
                                <input type="text" name="nombre" class="form-control"
                                       value="<%= usuarioPerfil.nombre %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Apellido</label>
                                <input type="text" name="apellido" class="form-control"
                                       value="<%= usuarioPerfil.apellido %>" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Semestre</label>
                                <select name="semestre" class="form-select" required>
                                    <option value="1" <%= usuarioPerfil.semestre == 1 ? 'selected' : '' %>>1</option>
                                    <option value="2" <%= usuarioPerfil.semestre == 2 ? 'selected' : '' %>>2</option>
                                </select>
                            </div>
                            <div class="col-md-8 mb-3">
                                <label class="form-label fw-bold">Programa académico</label>
                                <input type="text" name="programa" class="form-control"
                                       value="<%= usuarioPerfil.programa %>" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo electrónico</label>
                            <input type="email" class="form-control" value="<%= usuarioPerfil.email %>" disabled>
                            <small class="text-muted">El correo no se puede cambiar.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Código estudiantil</label>
                            <input type="text" class="form-control" value="<%= usuarioPerfil.codigo %>" disabled>
                            <small class="text-muted">El código no se puede cambiar.</small>
                        </div>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>Guardar cambios
                        </button>
                    </form>
                </div>
                <div class="card p-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-award-fill me-2 text-warning"></i>Mis Logros</h6>
                    <div class="row g-3">
                        <% logros.forEach(l => { %>
                        <div class="col-6 col-md-4">
                            <div class="logro-card <%= l.fecha_obtenido ? 'obtenido' : 'pendiente' %>">
                                <div class="fs-3 mb-1"><%= l.icono %></div>
                                <p class="fw-bold small mb-0"><%= l.nombre %></p>
                                <small class="text-muted"><%= l.descripcion %></small>
                                <% if (l.fecha_obtenido) { %>
                                <div class="mt-1"><span class="badge bg-primary"><%= l.puntos_otorgados %> pts</span></div>
                                <% } else { %>
                                <div class="mt-1"><small class="text-muted"><%= l.proyectos_requeridos %> proyectos</small></div>
                                <% } %>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
