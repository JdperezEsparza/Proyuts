<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Mi Perfil' }) %>
    <style>
        :root {
            --verde-uts: #C3D730;
            --verde-uts-suave: #F0F5CC;
            --verde-uts-oscuro: #7A8A00;
            --gris-claro: #B3B3B3;
            --gris-medio: #878787;
            --fondo: #F5F5F5;
            --oscuro: #1A1A1A;
        }

        body { background-color: var(--fondo); }

        /* === BOTÓN VOLVER === */
        .btn-volver {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 10px;
            padding: 4px 12px;
            font-size: 0.9rem;
            transition: border-color 0.2s, color 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        .btn-volver:hover { border-color: var(--oscuro); color: var(--oscuro); }

        /* === ÍCONO TÍTULO === */
        .icon-titulo { color: var(--verde-uts-oscuro); }

        /* === CARDS === */
        .card {
            border: 1px solid #E5E5E5 !important;
            border-radius: 16px;
            background: #fff;
        }

        /* === AVATAR === */
        .avatar {
            width: 90px; height: 90px; border-radius: 50%;
            background: var(--verde-uts);
            display: flex; align-items: center; justify-content: center;
            font-size: 2.2rem; color: var(--oscuro); font-weight: 800;
        }

        /* === BADGE PROGRAMA === */
        .badge-programa {
            background: var(--verde-uts);
            color: var(--oscuro);
            font-weight: 700;
            font-size: 0.8rem;
            border-radius: 8px;
            padding: 4px 12px;
        }

        /* === STATS DEL PERFIL === */
        .stat-puntos    { color: var(--verde-uts-oscuro); }
        .stat-terminado { color: #2e7d32; }
        .stat-faltan    { color: #E53935; }
        .stat-total     { color: var(--verde-uts-oscuro); }

        /* === STAT BOX RESUMEN === */
        .stat-box {
            border-radius: 12px;
            padding: 14px;
            text-align: center;
            background: var(--verde-uts-suave);
        }

        /* === BARRA DE PROGRESO === */
        .progress-bar-uts {
            background-color: var(--verde-uts) !important;
            border-radius: 8px;
        }

        /* === INPUTS FOCUS === */
        .form-control:focus,
        .form-select:focus {
            border-color: var(--verde-uts);
            box-shadow: 0 0 0 3px rgba(195, 215, 48, 0.2);
        }

        /* === BOTÓN GUARDAR === */
        .btn-uts {
            background: var(--verde-uts);
            color: var(--oscuro);
            font-weight: 700;
            border: none;
            border-radius: 10px;
            padding: 8px 24px;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background 0.2s;
            cursor: pointer;
        }
        .btn-uts:hover { background: #b0c228; color: var(--oscuro); }

        /* === LOGROS === */
        .logro-card {
            border-radius: 12px;
            border: 1px solid #E5E5E5;
            padding: 14px;
            text-align: center;
            transition: transform 0.2s;
            background: #fff;
        }
        .logro-card.obtenido {
            border-color: var(--verde-uts);
            background-color: var(--verde-uts-suave);
        }
        .logro-card.pendiente { opacity: 0.45; }
        .logro-card:hover { transform: translateY(-3px); }

        .badge-logro {
            background: var(--verde-uts);
            color: var(--oscuro);
            font-weight: 700;
            font-size: 0.75rem;
            border-radius: 8px;
            padding: 2px 8px;
        }

        /* === ALERTAS === */
        .alerta-ok {
            background: #F0F5CC;
            border: 1px solid var(--verde-uts);
            color: var(--verde-uts-oscuro);
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .alerta-error {
            background: #FFEBEE;
            border: 1px solid #E53935;
            color: #B71C1C;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .btn-close-alerta {
            background: transparent;
            border: none;
            font-size: 1rem;
            cursor: pointer;
            color: inherit;
            opacity: 0.6;
            line-height: 1;
        }
        .btn-close-alerta:hover { opacity: 1; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn-volver me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-person-circle me-2 icon-titulo"></i>Mi Perfil
            </h4>
        </div>

        <% if (mensaje === 'actualizado') { %>
        <div class="alerta-ok mb-3">
            <span><i class="bi bi-check-circle me-2"></i>Perfil actualizado correctamente.</span>
            <button class="btn-close-alerta" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% } %>
        <% if (error) { %>
        <div class="alerta-error mb-3">
            <span><i class="bi bi-exclamation-circle me-2"></i><%= error %></span>
            <button class="btn-close-alerta" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% } %>

        <div class="row g-4">

            <!-- Columna izquierda -->
            <div class="col-md-4">
                <div class="card p-4 text-center mb-4">
                    <div class="avatar mx-auto mb-3">
                        <%= usuarioPerfil.nombre.charAt(0).toUpperCase() %><%= usuarioPerfil.apellido.charAt(0).toUpperCase() %>
                    </div>
                    <h5 class="fw-bold mb-0"><%= usuarioPerfil.getNombreCompleto() %></h5>
                    <p class="text-muted small mb-2"><%= usuarioPerfil.email %></p>
                    <span class="badge-programa"><%= usuarioPerfil.programa %></span>
                    <hr class="my-3">
                    <div class="d-flex justify-content-around">
                        <div>
                            <h5 class="fw-bold stat-puntos mb-0"><%= usuarioPerfil.puntos %></h5>
                            <small class="text-muted">Puntos</small>
                        </div>
                        <div>
                            <h5 class="fw-bold stat-terminado mb-0"><%= terminados %></h5>
                            <small class="text-muted">Terminados</small>
                        </div>
                        <div>
                            <h5 class="fw-bold stat-faltan mb-0"><%= faltan %></h5>
                            <small class="text-muted">Faltan</small>
                        </div>
                    </div>
                </div>

                <div class="card p-3">
                    <h6 class="fw-bold mb-3">Resumen</h6>
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="stat-box">
                                <h5 class="fw-bold stat-total mb-0"><%= total %></h5>
                                <small class="text-muted">Total</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-box">
                                <h5 class="fw-bold stat-terminado mb-0"><%= terminados %></h5>
                                <small class="text-muted">Terminados</small>
                            </div>
                        </div>
                        <div class="col-12 mt-2">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="fw-bold">Progreso</small>
                                <small class="text-muted"><%= terminados %>/52</small>
                            </div>
                            <div class="progress" style="height:10px; border-radius:8px; background:#EEEEEE;">
                                <div class="progress-bar-uts progress-bar" role="progressbar"
                                     style="width:<%= Math.min(100,(terminados/52)*100) %>%; border-radius:8px;">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Columna derecha -->
            <div class="col-md-8">
                <div class="card p-4 mb-4">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-pencil me-2 icon-titulo"></i>Editar información
                    </h6>
                    <form action="/perfil" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nombre</label>
                                <input type="text" name="nombre" class="form-control"
                                       value="<%= usuarioPerfil.nombre %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Apellido</label>
                                <input type="text" name="apellido" class="form-control"
                                       value="<%= usuarioPerfil.apellido %>" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Semestre</label>
                                <select name="semestre" class="form-select" required>
                                    <option value="1" <%= usuarioPerfil.semestre == 1 ? 'selected' : '' %>>1</option>
                                    <option value="2" <%= usuarioPerfil.semestre == 2 ? 'selected' : '' %>>2</option>
                                </select>
                            </div>
                            <div class="col-md-8 mb-3">
                                <label class="form-label fw-bold">Programa académico</label>
                                <input type="text" name="programa" class="form-control"
                                       value="<%= usuarioPerfil.programa %>" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo electrónico</label>
                            <input type="email" class="form-control" value="<%= usuarioPerfil.email %>" disabled>
                            <small class="text-muted">El correo no se puede cambiar.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Código estudiantil</label>
                            <input type="text" class="form-control" value="<%= usuarioPerfil.codigo %>" disabled>
                            <small class="text-muted">El código no se puede cambiar.</small>
                        </div>
                        <button type="submit" class="btn-uts">
                            <i class="bi bi-check-circle"></i>Guardar cambios
                        </button>
                    </form>
                </div>

                <div class="card p-4">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-award-fill me-2" style="color:#F57C00;"></i>Mis Logros
                    </h6>
                    <div class="row g-3">
                        <% logros.forEach(l => { %>
                        <div class="col-6 col-md-4">
                            <div class="logro-card <%= l.fecha_obtenido ? 'obtenido' : 'pendiente' %>">
                                <div class="fs-3 mb-1"><%= l.icono %></div>
                                <p class="fw-bold small mb-0"><%= l.nombre %></p>
                                <small class="text-muted"><%= l.descripcion %></small>
                                <% if (l.fecha_obtenido) { %>
                                <div class="mt-1"><span class="badge-logro"><%= l.puntos_otorgados %> pts</span></div>
                                <% } else { %>
                                <div class="mt-1"><small class="text-muted"><%= l.proyectos_requeridos %> proyectos</small></div>
                                <% } %>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
