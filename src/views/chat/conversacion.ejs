<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Chat' }) %>
    <style>
        .chat-box {
            height: 450px; overflow-y: auto; padding: 16px;
            display: flex; flex-direction: column; gap: 10px;
            background: var(--bg-input); border-radius: 12px;
        }
        .burbuja {
            max-width: 70%; padding: 10px 14px; border-radius: 18px;
            font-size: 0.93rem; word-break: break-word;
        }
        .burbuja.mia {
            background-color: #1a237e; color: white;
            align-self: flex-end; border-bottom-right-radius: 4px;
        }
        .burbuja.suya {
            background-color: var(--bg-card); color: var(--text-primary);
            align-self: flex-start; border-bottom-left-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        .hora { font-size: 0.72rem; opacity: 0.7; margin-top: 3px; }
        .avatar-sm {
            width: 42px; height: 42px; border-radius: 50%;
            background: linear-gradient(135deg, #1a237e, #3949ab);
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; color: white; font-size: 0.9rem; flex-shrink: 0;
        }
        .input-mensaje {
            border-radius: 24px; border: 2px solid var(--border-color);
            padding: 10px 18px; font-size: 0.95rem; resize: none;
            background: var(--bg-input); color: var(--text-primary);
        }
        .input-mensaje:focus { border-color: #1a237e; box-shadow: none; }
        .btn-enviar {
            width: 46px; height: 46px; border-radius: 50%;
            background-color: #1a237e; border: none; color: white;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .btn-enviar:hover { background-color: #283593; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card mb-0" style="border-radius:16px 16px 0 0;">
                    <div class="d-flex align-items-center gap-3 p-3">
                        <a href="/chat" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
                        <div class="avatar-sm">
                            <%= destinatario.nombre.charAt(0) %><%= destinatario.apellido.charAt(0) %>
                        </div>
                        <div>
                            <p class="fw-bold mb-0"><%= destinatario.getNombreCompleto() %></p>
                            <small class="text-muted"><%= destinatario.programa %> · Código: <%= destinatario.codigo %></small>
                        </div>
                    </div>
                </div>
                <div class="chat-box" id="chatBox">
                    <% if (mensajes.length === 0) { %>
                    <div class="text-center text-muted my-auto">
                        <i class="bi bi-chat-dots fs-1 d-block mb-2"></i>
                        <p>Aún no hay mensajes. ¡Di hola!</p>
                    </div>
                    <% } else { %>
                        <% mensajes.forEach(m => { %>
                        <div class="d-flex flex-column <%= m.remitente_id === usuario.id ? 'align-items-end' : 'align-items-start' %>">
                            <div class="burbuja <%= m.remitente_id === usuario.id ? 'mia' : 'suya' %>">
                                <%= m.contenido %>
                            </div>
                            <small class="hora text-muted">
                                <%= new Date(m.fecha_envio).toLocaleTimeString('es-CO', { hour:'2-digit', minute:'2-digit' }) %>
                                · <%= new Date(m.fecha_envio).toLocaleDateString('es-CO') %>
                            </small>
                        </div>
                        <% }) %>
                    <% } %>
                </div>
                <div class="card p-3" style="border-radius:0 0 16px 16px; border-top:1px solid var(--border-color);">
                    <form action="/chat/<%= destinatario.id %>" method="POST">
                        <div class="d-flex align-items-center gap-2">
                            <textarea name="contenido" class="form-control input-mensaje"
                                      rows="1" placeholder="Escribe un mensaje..."
                                      onkeydown="if(event.key==='Enter' && !event.shiftKey){ event.preventDefault(); this.form.submit(); }"></textarea>
                            <button type="submit" class="btn-enviar">
                                <i class="bi bi-send-fill"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
    <script>
        const chatBox = document.getElementById('chatBox');
        chatBox.scrollTop = chatBox.scrollHeight;
    </script>
</body>
</html>
