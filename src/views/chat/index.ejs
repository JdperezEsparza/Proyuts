<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Chat' }) %>
    <style>
        .conversacion-item {
            border-radius: 12px; padding: 12px 16px; cursor: pointer;
            transition: background 0.2s; text-decoration: none; color: inherit; display: block;
        }
        .conversacion-item:hover { background-color: var(--bg-hover); color: inherit; }
        .avatar-sm {
            width: 46px; height: 46px; border-radius: 50%;
            background: linear-gradient(135deg, #1a237e, #3949ab);
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; color: white; font-size: 1rem; flex-shrink: 0;
        }
        .btn-primary { background-color: #1a237e; border-color: #1a237e; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">
        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0"><i class="bi bi-chat-dots me-2 text-primary"></i>Chat</h4>
        </div>
        <div class="row g-4">
            <div class="col-md-7">
                <div class="card p-3">
                    <h6 class="fw-bold mb-3">Conversaciones</h6>
                    <% if (conversaciones.length === 0) { %>
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-chat-dots fs-1 d-block mb-2"></i>
                        <p>No tienes conversaciones aún.</p>
                        <small>Selecciona un estudiante de la lista para comenzar.</small>
                    </div>
                    <% } else { %>
                        <% conversaciones.forEach(c => { %>
                        <a href="/chat/<%= c.id %>" class="conversacion-item">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-sm"><%= c.nombre.charAt(0) %><%= c.apellido.charAt(0) %></div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="fw-bold mb-0"><%= c.nombre %> <%= c.apellido %></p>
                                        <small class="text-muted"><%= new Date(c.ultima_fecha).toLocaleDateString('es-CO') %></small>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted text-truncate">
                                            <%= c.remitente_id === usuario.id ? 'Tú: ' : '' %><%= c.ultimo_mensaje %>
                                        </small>
                                        <% if (c.no_leidos > 0) { %>
                                        <span class="badge bg-primary rounded-pill ms-2"><%= c.no_leidos %></span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </a>
                        <% }) %>
                    <% } %>
                </div>
            </div>
            <div class="col-md-5">
                <div class="card p-3">
                    <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle me-2 text-primary"></i>Nuevo mensaje</h6>
                    <input type="text" id="buscarUsuario" class="form-control mb-3" placeholder="Buscar estudiante...">
                    <div id="listaUsuarios" style="max-height:350px; overflow-y:auto;">
                        <% if (usuarios.length === 0) { %>
                        <p class="text-muted text-center small">No hay otros estudiantes registrados.</p>
                        <% } else { %>
                            <% usuarios.forEach(u => { %>
                            <a href="/chat/<%= u.id %>" class="conversacion-item mb-1">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-sm" style="width:36px; height:36px; font-size:0.8rem;">
                                        <%= u.nombre.charAt(0) %><%= u.apellido.charAt(0) %>
                                    </div>
                                    <div>
                                        <p class="fw-bold mb-0 small"><%= u.nombre %> <%= u.apellido %></p>
                                        <small class="text-muted"><%= u.programa %></small>
                                    </div>
                                </div>
                            </a>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
    <script>
        document.getElementById('buscarUsuario').addEventListener('input', function() {
            const filtro = this.value.toLowerCase();
            document.querySelectorAll('#listaUsuarios a').forEach(item => {
                const nombre = item.querySelector('p').textContent.toLowerCase();
                item.style.display = nombre.includes(filtro) ? 'block' : 'none';
            });
        });
    </script>
</body>
</html>
