<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Panel Admin' }) %>
    <style>
        .stat-card { border-radius: 16px; border: none; box-shadow: var(--shadow); padding: 20px; background: var(--bg-card); }
        .admin-banner { background: linear-gradient(135deg, #1a237e, #3949ab); color: white; border-radius: 16px; padding: 20px 24px; }
        .acceso-card { border-radius: 12px; border: none; box-shadow: var(--shadow); color: inherit; text-decoration: none; transition: transform 0.2s; }
        .acceso-card:hover { transform: translateY(-3px); color: inherit; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-shield-fill-check me-2 text-primary"></i>Panel de Administración
            </h4>
        </div>

        <div class="admin-banner mb-4">
            <h5 class="fw-bold mb-1">Bienvenido, <%= usuario.nombre %></h5>
            <p class="mb-0 opacity-75">Desde aquí puedes gestionar usuarios, profesores, cursos y ver estadísticas generales del sistema.</p>
        </div>

        <!-- Estadísticas -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <i class="bi bi-people-fill fs-2 text-primary mb-2 d-block"></i>
                    <h3 class="fw-bold text-primary mb-0"><%= totalUsuarios %></h3>
                    <small class="text-muted">Estudiantes</small>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <i class="bi bi-person-workspace fs-2 text-info mb-2 d-block"></i>
                    <h3 class="fw-bold text-info mb-0"><%= totalProfesores %></h3>
                    <small class="text-muted">Profesores</small>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <i class="bi bi-folder2-open fs-2 text-success mb-2 d-block"></i>
                    <h3 class="fw-bold text-success mb-0"><%= totalProyectos %></h3>
                    <small class="text-muted">Proyectos totales</small>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <i class="bi bi-check-circle-fill fs-2 text-success mb-2 d-block"></i>
                    <h3 class="fw-bold text-success mb-0"><%= totalTerminados %></h3>
                    <small class="text-muted">Proyectos aprobados</small>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <i class="bi bi-book-fill fs-2 text-warning mb-2 d-block"></i>
                    <h3 class="fw-bold text-warning mb-0"><%= totalCursos %></h3>
                    <small class="text-muted">Cursos activos</small>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card text-center">
                    <i class="bi bi-chat-dots-fill fs-2 text-info mb-2 d-block"></i>
                    <h3 class="fw-bold text-info mb-0"><%= totalMensajes %></h3>
                    <small class="text-muted">Mensajes</small>
                </div>
            </div>
        </div>

        <!-- Accesos rápidos -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <a href="/admin/usuarios" class="acceso-card card p-3 d-flex flex-row align-items-center gap-3">
                    <i class="bi bi-people-fill fs-2 text-primary"></i>
                    <div>
                        <p class="fw-bold mb-0 small">Estudiantes</p>
                        <small class="text-muted">Ver y gestionar</small>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/admin/profesores" class="acceso-card card p-3 d-flex flex-row align-items-center gap-3">
                    <i class="bi bi-person-workspace fs-2 text-info"></i>
                    <div>
                        <p class="fw-bold mb-0 small">Profesores</p>
                        <small class="text-muted">Asignar cursos</small>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/admin/cursos" class="acceso-card card p-3 d-flex flex-row align-items-center gap-3">
                    <i class="bi bi-book-fill fs-2 text-warning"></i>
                    <div>
                        <p class="fw-bold mb-0 small">Cursos</p>
                        <small class="text-muted">CRUD de cursos</small>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/anuncios/nuevo" class="acceso-card card p-3 d-flex flex-row align-items-center gap-3">
                    <i class="bi bi-megaphone-fill fs-2 text-danger"></i>
                    <div>
                        <p class="fw-bold mb-0 small">Anuncio</p>
                        <small class="text-muted">Publicar nuevo</small>
                    </div>
                </a>
            </div>
        </div>

        <div class="row g-4">
            <!-- Últimos registrados -->
            <div class="col-md-6">
                <div class="card p-3" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
                    <h6 class="fw-bold mb-3"><i class="bi bi-clock-history me-2 text-primary"></i>Últimos estudiantes</h6>
                    <% ultimosUsuarios.forEach(u => { %>
                    <div class="d-flex align-items-center gap-3 py-2 border-bottom">
                        <div style="width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,#1a237e,#3949ab); display:flex; align-items:center; justify-content:center; color:white; font-weight:800; font-size:0.85rem; flex-shrink:0;">
                            <%= u.nombre.charAt(0) %><%= u.apellido.charAt(0) %>
                        </div>
                        <div class="flex-grow-1">
                            <p class="fw-bold mb-0 small"><%= u.nombre %> <%= u.apellido %></p>
                            <small class="text-muted"><%= u.programa %></small>
                        </div>
                        <small class="text-muted"><%= new Date(u.fecha_registro).toLocaleDateString('es-CO') %></small>
                    </div>
                    <% }) %>
                </div>
            </div>

            <!-- Top 5 -->
            <div class="col-md-6">
                <div class="card p-3" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
                    <h6 class="fw-bold mb-3"><i class="bi bi-trophy-fill me-2 text-warning"></i>Top 5 estudiantes</h6>
                    <% topEstudiantes.forEach((u, i) => { %>
                    <div class="d-flex align-items-center gap-3 py-2 border-bottom">
                        <span class="fw-bold text-muted">#<%= i + 1 %></span>
                        <div class="flex-grow-1">
                            <p class="fw-bold mb-0 small"><%= u.nombre %> <%= u.apellido %></p>
                            <small class="text-muted"><%= u.codigo %></small>
                        </div>
                        <div class="text-end">
                            <p class="fw-bold mb-0 text-success small"><%= u.terminados %> proyectos</p>
                            <small class="text-muted"><%= u.puntos %> pts</small>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
