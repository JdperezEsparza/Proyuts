<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Gestionar Cursos' }) %>
    <style>
        .btn-primary { background-color: #1a237e; border-color: #1a237e; }
        .btn-primary:hover { background-color: #283593; border-color: #283593; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center">
                <a href="/admin" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
                <h4 class="fw-bold mb-0">
                    <i class="bi bi-book-fill me-2 text-warning"></i>Gestionar Cursos
                </h4>
            </div>
            <a href="/admin/cursos/nuevo" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Nuevo curso
            </a>
        </div>

        <% if (mensaje === 'creado') { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>Curso creado correctamente.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } else if (mensaje === 'actualizado') { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>Curso actualizado correctamente.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } else if (mensaje === 'eliminado') { %>
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-trash me-2"></i>Curso eliminado.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>

        <div class="card p-3" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
            <% if (cursos.length === 0) { %>
            <div class="text-center text-muted py-4">
                <i class="bi bi-book fs-1 d-block mb-2"></i>
                <p>No hay cursos registrados.</p>
            </div>
            <% } else { %>
                <% cursos.forEach(c => { %>
                <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2">
                            <h6 class="fw-bold mb-0"><%= c.nombre %></h6>
                            <span class="badge <%= c.activo ? 'bg-success' : 'bg-secondary' %>">
                                <%= c.activo ? 'Activo' : 'Inactivo' %>
                            </span>
                        </div>
                        <% if (c.descripcion) { %>
                        <small class="text-muted"><%= c.descripcion %></small>
                        <% } %>
                        <div class="d-flex gap-3 mt-1">
                            <small class="text-muted"><i class="bi bi-bookmark me-1"></i>Semestre <%= c.semestre %></small>
                            <small class="text-muted"><i class="bi bi-star me-1"></i><%= c.creditos %> créditos</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/admin/cursos/<%= c.id %>/editar" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form action="/admin/cursos/<%= c.id %>/eliminar" method="POST"
                              onsubmit="return confirm('¿Seguro que quieres eliminar este curso?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
                <% }) %>
            <% } %>
        </div>
    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
