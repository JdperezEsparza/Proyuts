<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Gestionar Profesores' }) %>
    <style>
        .btn-primary { background-color: #1a237e; border-color: #1a237e; }
        .btn-primary:hover { background-color: #283593; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <div class="d-flex align-items-center mb-4">
            <a href="/admin" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-person-workspace me-2 text-primary"></i>Gestionar Profesores
            </h4>
        </div>

        <!-- Alertas -->
        <% if (mensaje === 'asignado') { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>Curso asignado correctamente.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } else if (mensaje === 'quitado') { %>
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-info-circle me-2"></i>Curso quitado al profesor.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } else if (mensaje === 'quitado-rol') { %>
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-person-dash me-2"></i>Rol de profesor removido.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>

        <% if (profesores.length === 0) { %>
        <div class="card p-5 text-center" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
            <i class="bi bi-person-workspace fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">No hay profesores registrados aún</h5>
            <p class="text-muted small">Ve a <a href="/admin/usuarios">Gestionar Usuarios</a> y convierte un estudiante en profesor.</p>
        </div>
        <% } else { %>
            <% profesores.forEach(p => { %>
            <div class="card p-4 mb-3" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
                <div class="d-flex align-items-start gap-3">

                    <!-- Avatar -->
                    <div style="width:50px; height:50px; border-radius:50%; background:linear-gradient(135deg,#1a237e,#3949ab); display:flex; align-items:center; justify-content:center; color:white; font-weight:800; flex-shrink:0;">
                        <%= p.nombre.charAt(0) %><%= p.apellido.charAt(0) %>
                    </div>

                    <!-- Info -->
                    <div class="flex-grow-1">
                        <h6 class="fw-bold mb-0"><%= p.nombre %> <%= p.apellido %></h6>
                        <small class="text-muted"><%= p.email %> · <%= p.codigo %></small>

                        <!-- Cursos asignados -->
                        <div class="mt-2">
                            <small class="fw-bold text-muted d-block mb-1">Cursos asignados:</small>
                            <% if (p.cursos_asignados) { %>
                                <% p.cursos_asignados.split(', ').forEach(curso => { %>
                                <span class="badge bg-primary me-1"><%= curso %></span>
                                <% }) %>
                            <% } else { %>
                            <small class="text-muted">Sin cursos asignados</small>
                            <% } %>
                        </div>

                        <!-- Asignar nuevo curso -->
                        <form action="/admin/profesores/<%= p.id %>/asignar-curso" method="POST"
                              class="d-flex gap-2 mt-3">
                            <select name="curso_id" class="form-select form-select-sm" required>
                                <option value="">-- Asignar curso --</option>
                                <% cursos.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.nombre %></option>
                                <% }) %>
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus-circle me-1"></i>Asignar
                            </button>
                        </form>

                        <!-- Quitar curso -->
                        <% if (p.cursos_asignados) { %>
                        <form action="/admin/profesores/<%= p.id %>/quitar-curso" method="POST"
                              class="d-flex gap-2 mt-2">
                            <select name="curso_id" class="form-select form-select-sm" required>
                                <option value="">-- Quitar curso --</option>
                                <% cursos.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.nombre %></option>
                                <% }) %>
                            </select>
                            <button type="submit" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-dash-circle me-1"></i>Quitar
                            </button>
                        </form>
                        <% } %>
                    </div>

                    <!-- Quitar rol -->
                    <form action="/admin/profesores/<%= p.id %>/quitar-rol" method="POST"
                          onsubmit="return confirm('¿Quitar el rol de profesor a <%= p.nombre %>?')">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-person-dash me-1"></i>Quitar rol
                        </button>
                    </form>
                </div>
            </div>
            <% }) %>
        <% } %>

    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
