<%# ============================================
    ProyUts - Registro
    src/views/auth/registro.ejs
    ============================================ %>
<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Registro' }) %>
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--bg-body);
            padding: 30px 0;
        }

        .registro-card {
            width: 100%;
            max-width: 500px;
            background: var(--bg-card);
            border: 2px solid #C3D730;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 8px 32px rgba(195, 215, 48, 0.15);
        }

        .logo-title {
            color: #C3D730;
            font-weight: 800;
            font-size: 2rem;
        }

        .btn-registrar {
            background-color: #C3D730;
            border: none;
            color: #1A1A1A;
            font-weight: 700;
            font-size: 1rem;
            padding: 12px;
            border-radius: 10px;
            width: 100%;
            transition: background 0.2s;
        }

        .btn-registrar:hover {
            background-color: #afc024;
        }

        .btn-tema-login {
            position: fixed;
            top: 16px;
            right: 16px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            box-shadow: var(--shadow);
            transition: background 0.2s;
        }

        .btn-tema-login:hover {
            background: var(--bg-hover);
        }

        .link-login {
            color: #C3D730;
            font-weight: 700;
            text-decoration: none;
        }

        .link-login:hover {
            color: #afc024;
        }
    </style>
</head>
<body>

    <!-- Botón de tema flotante -->
    <button class="btn-tema-login" id="btnTema" onclick="toggleTema()" title="Cambiar tema"></button>

    <div class="registro-card">

        <!-- Logo -->
        <div class="text-center mb-4">
            <h1 class="logo-title">ProyUts</h1>
            <p class="text-muted small">Crear nueva cuenta</p>
        </div>

        <!-- Error -->
        <% if (error) { %>
        <div class="alert alert-danger small">
            <i class="bi bi-exclamation-circle me-2"></i><%= error %>
        </div>
        <% } %>

        <!-- Formulario -->
        <form action="/registro" method="POST">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold small">Nombre</label>
                    <input type="text" name="nombre" class="form-control"
                           placeholder="Tu nombre" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold small">Apellido</label>
                    <input type="text" name="apellido" class="form-control"
                           placeholder="Tu apellido" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold small">Código estudiantil</label>
                <input type="text" name="codigo" class="form-control"
                       placeholder="Ej: 20231234" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold small">Correo electrónico</label>
                <input type="email" name="email" class="form-control"
                       placeholder="ejemplo@uts.edu.co" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold small">Contraseña</label>
                <input type="password" name="contrasena" class="form-control"
                       placeholder="Mínimo 6 caracteres" required minlength="6">
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold small">Semestre</label>
                    <select name="semestre" class="form-select" required>
                        <option value="">--</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                    </select>
                </div>
                <div class="col-md-8 mb-3">
                    <label class="form-label fw-bold small">Programa académico</label>
                    <input type="text" name="programa" class="form-control"
                           placeholder="Ej: Ingeniería de Sistemas" required>
                </div>
            </div>

            <button type="submit" class="btn-registrar mt-2">
                <i class="bi bi-person-plus me-2"></i>Crear cuenta
            </button>
        </form>

        <hr class="my-4">

        <p class="text-center text-muted small mb-0">
            ¿Ya tienes cuenta?
            <a href="/login" class="link-login">Inicia sesión</a>
        </p>

    </div>

    <%- include('../partials/scripts') %>
</body>
</html>
