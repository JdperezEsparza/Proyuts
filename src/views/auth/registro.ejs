<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Registro' }) %>
    <style>
        body {
            background: #1A1A1A;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px 0;
        }

        /* === CARD === */
        .card-registro {
            background: #ffffff;
            border-radius: 20px;
            border: none;
            padding: 2rem 2rem;
            box-shadow: 0 12px 40px rgba(0,0,0,0.3);
        }

        /* === LOGO === */
        .logo-title {
            color: #C3D730;
            font-weight: 800;
            font-size: 2rem;
            letter-spacing: -1px;
        }
        .logo-sub { color: #878787; font-size: 0.95rem; }

        /* === ACENTO SUPERIOR === */
        .card-accent {
            height: 4px;
            background: #C3D730;
            border-radius: 20px 20px 0 0;
            margin: -2rem -2rem 1.5rem -2rem;
            border-radius: 20px 20px 0 0;
        }

        /* === INPUTS === */
        .form-control:focus,
        .form-select:focus {
            border-color: #C3D730;
            box-shadow: 0 0 0 3px rgba(195, 215, 48, 0.2);
        }

        /* === BOTÓN CREAR CUENTA === */
        .btn-uts {
            background: #C3D730;
            color: #1A1A1A;
            font-weight: 700;
            border: none;
            border-radius: 10px;
            padding: 10px;
            font-size: 1rem;
            width: 100%;
            cursor: pointer;
            transition: background 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-uts:hover { background: #b0c228; }

        /* === LINK LOGIN === */
        .link-login {
            color: #7A8A00;
            font-weight: 700;
            text-decoration: none;
        }
        .link-login:hover { color: #C3D730; }

        /* === ALERTA ERROR === */
        .alerta-error {
            background: #FFEBEE;
            border: 1px solid #E53935;
            color: #B71C1C;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card-registro">
                    <div class="card-accent"></div>

                    <div class="text-center mb-4">
                        <div class="logo-title">ProyUts</div>
                        <p class="logo-sub mb-0">Crear nueva cuenta</p>
                    </div>

                    <% if (error) { %>
                    <div class="alerta-error">
                        <i class="bi bi-exclamation-circle me-2"></i><%= error %>
                    </div>
                    <% } %>

                    <form action="/registro" method="POST">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nombre</label>
                                <input type="text" name="nombre" class="form-control"
                                       placeholder="Tu nombre" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Apellido</label>
                                <input type="text" name="apellido" class="form-control"
                                       placeholder="Tu apellido" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Código estudiantil</label>
                            <input type="text" name="codigo" class="form-control"
                                   placeholder="Ej: 20231234" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo electrónico</label>
                            <input type="email" name="email" class="form-control"
                                   placeholder="ejemplo@uts.edu.co" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Contraseña</label>
                            <input type="password" name="contrasena" class="form-control"
                                   placeholder="Mínimo 6 caracteres" required minlength="6">
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Semestre</label>
                                <select name="semestre" class="form-select" required>
                                    <option value="">--</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                </select>
                            </div>
                            <div class="col-md-8 mb-3">
                                <label class="form-label fw-bold">Programa académico</label>
                                <input type="text" name="programa" class="form-control"
                                       placeholder="Ej: Ingeniería de Sistemas" required>
                            </div>
                        </div>
                        <button type="submit" class="btn-uts mt-2">
                            <i class="bi bi-person-plus"></i>Crear cuenta
                        </button>
                    </form>

                    <hr class="my-3">
                    <p class="text-center mb-0 text-muted">
                        ¿Ya tienes cuenta?
                        <a href="/login" class="link-login">Inicia sesión</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
