<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Ranking Top 10' }) %>
    <style>
        :root {
            --verde-uts: #C3D730;
            --verde-uts-suave: #F0F5CC;
            --verde-uts-oscuro: #7A8A00;
            --gris-claro: #B3B3B3;
            --gris-medio: #878787;
            --fondo: #F5F5F5;
            --oscuro: #1A1A1A;
        }

        body { background-color: var(--fondo); }

        /* === BOTÓN VOLVER === */
        .btn-volver {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 10px;
            padding: 4px 12px;
            font-size: 0.9rem;
            transition: border-color 0.2s, color 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        .btn-volver:hover { border-color: var(--oscuro); color: var(--oscuro); }

        /* === CARDS === */
        .card {
            border: 1px solid #E5E5E5 !important;
            border-radius: 16px;
            background: var(--bg-card, #fff);
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        }

        /* === MI POSICIÓN === */
        .mi-posicion {
            background: var(--oscuro);
            border-left: 5px solid var(--verde-uts);
            border-radius: 16px;
            padding: 16px 20px;
        }
        .mi-posicion p  { color: var(--gris-claro); margin-bottom: 0; }
        .mi-posicion h5 { color: #ffffff; margin-bottom: 0; }

        /* === PÓDIO === */
        .podio-card {
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            color: white;
            transition: transform 0.2s;
        }
        .podio-card:hover { transform: translateY(-4px); }
        .rank-1 { background: linear-gradient(135deg, #FFD700, #FFA500); }
        .rank-2 { background: linear-gradient(135deg, #C0C0C0, #A9A9A9); }
        .rank-3 { background: linear-gradient(135deg, #CD7F32, #A0522D); }

        /* === BADGES DE POSICIÓN === */
        .rank-badge {
            width: 42px; height: 42px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 1.1rem; flex-shrink: 0;
        }
        .rank-badge-1 { background: linear-gradient(135deg, #FFD700, #FFA500); color: white; }
        .rank-badge-2 { background: linear-gradient(135deg, #C0C0C0, #A9A9A9); color: white; }
        .rank-badge-3 { background: linear-gradient(135deg, #CD7F32, #A0522D); color: white; }
        .rank-other   { background-color: #EEEEEE; color: var(--gris-medio); }

        /* === BADGE TÚ === */
        .badge-tu {
            background: var(--verde-uts);
            color: var(--oscuro);
            font-weight: 700;
            font-size: 0.75rem;
            border-radius: 8px;
            padding: 2px 8px;
        }

        /* === PUNTOS EN TABLA === */
        .puntos-col {
            color: var(--verde-uts-oscuro);
            font-weight: 700;
        }

        /* === FILA HOVER === */
        .fila-ranking {
            border-radius: 8px;
            transition: background 0.15s;
        }
        .fila-ranking:hover { background: var(--verde-uts-suave); }
        .fila-ranking.yo    { background: var(--verde-uts-suave); }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn-volver me-3"><i class="bi bi-arrow-left"></i></a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-trophy-fill me-2" style="color:#F57C00;"></i>Ranking Top 10
            </h4>
        </div>

        <!-- Mi posición -->
        <div class="mi-posicion mb-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="small">Tu posición actual</p>
                    <h5 class="fw-bold">#<%= miPosicion %> en el ranking general</h5>
                </div>
                <div class="text-end">
                    <p class="small">Tus puntos</p>
                    <h5 class="fw-bold"><%= usuario.puntos || 0 %> pts</h5>
                </div>
            </div>
        </div>

        <!-- Pódio top 3 -->
        <% if (ranking.length >= 3) { %>
        <div class="row g-3 mb-4">
            <div class="col-4">
                <div class="podio-card rank-2 mt-4">
                    <div class="fs-2">2</div>
                    <p class="fw-bold mb-0"><%= ranking[1].nombre %> <%= ranking[1].apellido %></p>
                    <small><%= ranking[1].puntos %> pts</small><br>
                    <small><%= ranking[1].proyectos_terminados %> proyectos</small>
                </div>
            </div>
            <div class="col-4">
                <div class="podio-card rank-1">
                    <div class="fs-1">1</div>
                    <i class="bi bi-trophy-fill fs-4"></i>
                    <p class="fw-bold mb-0"><%= ranking[0].nombre %> <%= ranking[0].apellido %></p>
                    <small><%= ranking[0].puntos %> pts</small><br>
                    <small><%= ranking[0].proyectos_terminados %> proyectos</small>
                </div>
            </div>
            <div class="col-4">
                <div class="podio-card rank-3 mt-4">
                    <div class="fs-2">3</div>
                    <p class="fw-bold mb-0"><%= ranking[2].nombre %> <%= ranking[2].apellido %></p>
                    <small><%= ranking[2].puntos %> pts</small><br>
                    <small><%= ranking[2].proyectos_terminados %> proyectos</small>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Tabla completa -->
        <div class="card p-3">
            <h6 class="fw-bold mb-3">Tabla completa</h6>

            <% if (ranking.length === 0) { %>
            <div class="text-center text-muted py-4">
                <i class="bi bi-trophy fs-1 d-block mb-2" style="color:var(--gris-medio);"></i>
                Aún no hay datos en el ranking. ¡Sé el primero!
            </div>
            <% } else { %>
                <% ranking.forEach((u, i) => { %>
                <div class="fila-ranking d-flex align-items-center gap-3 py-2 <%= u.id === usuario.id ? 'yo' : '' %> <%= i < ranking.length - 1 ? 'border-bottom' : '' %>">
                    <div class="rank-badge <%= i === 0 ? 'rank-badge-1' : i === 1 ? 'rank-badge-2' : i === 2 ? 'rank-badge-3' : 'rank-other' %>">
                        <%= i + 1 %>
                    </div>
                    <div class="flex-grow-1">
                        <p class="fw-bold mb-0">
                            <%= u.nombre %> <%= u.apellido %>
                            <% if (u.id === usuario.id) { %>
                            <span class="badge-tu ms-1">Tú</span>
                            <% } %>
                        </p>
                        <small class="text-muted"><%= u.programa %> · Semestre <%= u.semestre %></small>
                    </div>
                    <div class="text-end">
                        <p class="puntos-col mb-0"><%= u.puntos %> pts</p>
                        <small class="text-muted"><%= u.proyectos_terminados %> proyectos</small>
                    </div>
                </div>
                <% }) %>
            <% } %>
        </div>

    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
