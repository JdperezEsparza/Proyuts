<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProyUts - Ranking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background-color: #f0f2f5; }
        .navbar { background-color: #1a237e !important; }
        .card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }
        .rank-1 { background: linear-gradient(135deg, #FFD700, #FFA500); color: white; }
        .rank-2 { background: linear-gradient(135deg, #C0C0C0, #A9A9A9); color: white; }
        .rank-3 { background: linear-gradient(135deg, #CD7F32, #A0522D); color: white; }
        .rank-badge {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        .rank-other { background-color: #e9ecef; color: #495057; }
        .podio-card {
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            color: white;
            transition: transform 0.2s;
        }
        .podio-card:hover { transform: translateY(-4px); }
        .mi-posicion {
            background: linear-gradient(135deg, #1a237e, #3949ab);
            color: white;
            border-radius: 16px;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-dark px-4 py-3">
        <a href="/dashboard" class="navbar-brand fw-bold fs-4">ProyUts</a>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white">
                <i class="bi bi-person-circle me-1"></i>
                <%= usuario.nombre %> <%= usuario.apellido %>
            </span>
            <a href="/logout" class="btn btn-outline-light btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Salir
            </a>
        </div>
    </nav>

    <div class="container py-4">

        <!-- Encabezado -->
        <div class="d-flex align-items-center mb-4">
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h4 class="fw-bold mb-0">
                <i class="bi bi-trophy-fill text-warning me-2"></i>Ranking Top 10
            </h4>
        </div>

        <!-- Mi posición -->
        <div class="mi-posicion p-3 mb-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="mb-0 opacity-75 small">Tu posición actual</p>
                    <h5 class="fw-bold mb-0">#<%= miPosicion %> en el ranking general</h5>
                </div>
                <div class="text-end">
                    <p class="mb-0 opacity-75 small">Tus puntos</p>
                    <h5 class="fw-bold mb-0"><%= usuario.puntos || 0 %> pts</h5>
                </div>
            </div>
        </div>

        <!-- Pódio top 3 -->
        <% if (ranking.length >= 3) { %>
        <div class="row g-3 mb-4">
            <!-- 2do lugar -->
            <div class="col-4">
                <div class="podio-card rank-2 mt-4">
                    <div class="fs-2">2</div>
                    <p class="fw-bold mb-0"><%= ranking[1].nombre %> <%= ranking[1].apellido %></p>
                    <small><%= ranking[1].puntos %> pts</small>
                    <br><small><%= ranking[1].proyectos_terminados %> proyectos</small>
                </div>
            </div>
            <!-- 1er lugar -->
            <div class="col-4">
                <div class="podio-card rank-1">
                    <div class="fs-1">1</div>
                    <i class="bi bi-trophy-fill fs-4"></i>
                    <p class="fw-bold mb-0"><%= ranking[0].nombre %> <%= ranking[0].apellido %></p>
                    <small><%= ranking[0].puntos %> pts</small>
                    <br><small><%= ranking[0].proyectos_terminados %> proyectos</small>
                </div>
            </div>
            <!-- 3er lugar -->
            <div class="col-4">
                <div class="podio-card rank-3 mt-4">
                    <div class="fs-2">3</div>
                    <p class="fw-bold mb-0"><%= ranking[2].nombre %> <%= ranking[2].apellido %></p>
                    <small><%= ranking[2].puntos %> pts</small>
                    <br><small><%= ranking[2].proyectos_terminados %> proyectos</small>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Tabla completa top 10 -->
        <div class="card p-3">
            <h6 class="fw-bold mb-3">Tabla completa</h6>
            <% ranking.forEach((u, i) => { %>
            <div class="d-flex align-items-center gap-3 py-2 <%= i < ranking.length - 1 ? 'border-bottom' : '' %>">
                <div class="rank-badge <%= i === 0 ? 'rank-1' : i === 1 ? 'rank-2' : i === 2 ? 'rank-3' : 'rank-other' %>">
                    <%= i + 1 %>
                </div>
                <div class="flex-grow-1">
                    <p class="fw-bold mb-0">
                        <%= u.nombre %> <%= u.apellido %>
                        <% if (u.id === usuario.id) { %>
                        <span class="badge bg-primary ms-1">Tú</span>
                        <% } %>
                    </p>
                    <small class="text-muted"><%= u.programa %> - Semestre <%= u.semestre %></small>
                </div>
                <div class="text-end">
                    <p class="fw-bold mb-0 text-primary"><%= u.puntos %> pts</p>
                    <small class="text-muted"><%= u.proyectos_terminados %> proyectos</small>
                </div>
            </div>
            <% }) %>

            <% if (ranking.length === 0) { %>
            <div class="text-center text-muted py-4">
                <i class="bi bi-trophy fs-1 d-block mb-2"></i>
                Aún no hay datos en el ranking. ¡Sé el primero!
            </div>
            <% } %>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
