<%# ============================================
    ProyUts - Iniciar Sesión
    src/views/auth/login.ejs
    ============================================ %>
<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Iniciar Sesión' }) %>
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--bg-body);
        }

        .login-card {
            width: 100%;
            max-width: 440px;
            background: var(--bg-card);
            border: 2px solid #C3D730;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 8px 32px rgba(195, 215, 48, 0.15);
        }

        .logo-title {
            color: #C3D730;
            font-weight: 800;
            font-size: 2.2rem;
        }

        .btn-ingresar {
            background-color: #C3D730;
            border: none;
            color: #1A1A1A;
            font-weight: 700;
            font-size: 1rem;
            padding: 12px;
            border-radius: 10px;
            width: 100%;
            transition: background 0.2s;
        }

        .btn-ingresar:hover {
            background-color: #afc024;
        }

        .btn-tema-login {
            position: fixed;
            top: 16px;
            right: 16px;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            box-shadow: var(--shadow);
            transition: background 0.2s;
        }

        .btn-tema-login:hover {
            background: var(--bg-hover);
        }

        .link-registro {
            color: #C3D730;
            font-weight: 700;
            text-decoration: none;
        }

        .link-registro:hover {
            color: #afc024;
        }
    </style>
</head>
<body>

    <!-- Botón de tema flotante -->
    <button class="btn-tema-login" id="btnTema" onclick="toggleTema()" title="Cambiar tema"></button>

    <div class="login-card">

        <!-- Logo -->
        <div class="text-center mb-4">
            <h1 class="logo-title">ProyUts</h1>
            <p class="text-muted small">Unidades Tecnológicas de Santander</p>
        </div>

        <!-- Alerta registro exitoso -->
        <% if (typeof query !== 'undefined' && query && query.registered) { %>
        <div class="alert alert-success small">
            <i class="bi bi-check-circle me-2"></i>Cuenta creada. Ya puedes iniciar sesión.
        </div>
        <% } %>

        <!-- Alerta de error -->
        <% if (error) { %>
        <div class="alert alert-danger small">
            <i class="bi bi-exclamation-circle me-2"></i><%= error %>
        </div>
        <% } %>

        <!-- Formulario -->
        <form action="/login" method="POST">
            <div class="mb-3">
                <label class="form-label fw-bold small">Correo electrónico</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" class="form-control"
                           placeholder="ejemplo@uts.edu.co" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold small">Contraseña</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input type="password" name="contrasena" class="form-control"
                           placeholder="Tu contraseña" required>
                </div>
            </div>

            <button type="submit" class="btn-ingresar">
                <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
            </button>
        </form>

        <hr class="my-4">

        <p class="text-center text-muted small mb-0">
            ¿No tienes cuenta?
            <a href="/registro" class="link-registro">Regístrate aquí</a>
        </p>

    </div>

    <%- include('../partials/scripts') %>
</body>
</html>
