<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Anuncios' }) %>
    <style>
        :root {
            --verde-uts: #C3D730;
            --verde-uts-suave: #F0F5CC;
            --verde-uts-oscuro: #7A8A00;
            --gris-claro: #B3B3B3;
            --gris-medio: #878787;
            --fondo: #F5F5F5;
            --oscuro: #1A1A1A;
        }

        body { background-color: var(--fondo); }

        /* === BOTÓN VOLVER === */
        .btn-volver {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 10px;
            padding: 4px 12px;
            font-size: 0.9rem;
            transition: border-color 0.2s, color 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        .btn-volver:hover { border-color: var(--oscuro); color: var(--oscuro); }

        /* === BOTÓN NUEVO ANUNCIO (solo admin) === */
        .btn-uts {
            background: var(--verde-uts);
            color: var(--oscuro);
            font-weight: 700;
            border: none;
            border-radius: 10px;
            padding: 7px 18px;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background 0.2s;
        }
        .btn-uts:hover { background: #b0c228; color: var(--oscuro); }

        /* === ANUNCIO CARDS === */
        .anuncio-card {
            border: 1px solid #E5E5E5 !important;
            border-radius: 12px;
            border-left: 5px solid var(--verde-uts) !important;
            background: var(--bg-card, #fff);
            box-shadow: var(--shadow);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .anuncio-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(195,215,48,0.15);
        }

        /* === CARD VACÍA === */
        .card-vacio {
            border: 1px solid #E5E5E5 !important;
            border-radius: 16px;
            background: var(--bg-card, #fff);
        }

        /* === BOTONES EDITAR / ELIMINAR === */
        .btn-editar {
            background: transparent;
            border: 1px solid var(--verde-uts-oscuro);
            color: var(--verde-uts-oscuro);
            border-radius: 8px;
            padding: 4px 10px;
            font-size: 0.85rem;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        .btn-editar:hover {
            background: var(--verde-uts);
            border-color: var(--verde-uts);
            color: var(--oscuro);
        }
        .btn-eliminar {
            background: transparent;
            border: 1px solid #E53935;
            color: #E53935;
            border-radius: 8px;
            padding: 4px 10px;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-eliminar:hover { background: #E53935; color: white; }

        /* === ALERTAS === */
        .alerta-ok {
            background: var(--verde-uts-suave);
            border: 1px solid var(--verde-uts);
            color: var(--verde-uts-oscuro);
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .alerta-warn {
            background: #FFF8E1;
            border: 1px solid #F57C00;
            color: #E65100;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .btn-close-alerta {
            background: transparent;
            border: none;
            font-size: 1rem;
            cursor: pointer;
            color: inherit;
            opacity: 0.6;
            line-height: 1;
        }
        .btn-close-alerta:hover { opacity: 1; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center">
                <a href="/dashboard" class="btn-volver me-3"><i class="bi bi-arrow-left"></i></a>
                <h4 class="fw-bold mb-0">
                    <i class="bi bi-megaphone me-2" style="color:var(--verde-uts-oscuro);"></i>Tablero de Anuncios
                </h4>
            </div>
            <% if (usuario.rol === 'admin') { %>
            <a href="/anuncios/nuevo" class="btn-uts">
                <i class="bi bi-plus-circle"></i>Nuevo anuncio
            </a>
            <% } %>
        </div>

        <% if (mensaje === 'creado') { %>
        <div class="alerta-ok mb-3">
            <span><i class="bi bi-check-circle me-2"></i>Anuncio publicado correctamente.</span>
            <button class="btn-close-alerta" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% } else if (mensaje === 'actualizado') { %>
        <div class="alerta-ok mb-3">
            <span><i class="bi bi-check-circle me-2"></i>Anuncio actualizado correctamente.</span>
            <button class="btn-close-alerta" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% } else if (mensaje === 'eliminado') { %>
        <div class="alerta-warn mb-3">
            <span><i class="bi bi-trash me-2"></i>Anuncio eliminado.</span>
            <button class="btn-close-alerta" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% } %>

        <% if (anuncios.length === 0) { %>
        <div class="card-vacio card p-5 text-center">
            <i class="bi bi-megaphone fs-1 d-block mb-3" style="color:var(--gris-medio);"></i>
            <h5 class="text-muted">No hay anuncios publicados aún</h5>
        </div>
        <% } else { %>
            <% anuncios.forEach(a => { %>
            <div class="anuncio-card card p-4 mb-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-1"><%= a.titulo %></h5>
                        <p class="text-muted mb-2" style="white-space:pre-line;"><%= a.contenido %></p>
                        <small class="text-muted">
                            <i class="bi bi-person me-1"></i><%= a.autor_nombre %> <%= a.autor_apellido %>
                            &nbsp;·&nbsp;
                            <i class="bi bi-calendar me-1"></i>
                            <%= new Date(a.fecha_publicacion).toLocaleDateString('es-CO', { year:'numeric', month:'long', day:'numeric' }) %>
                        </small>
                    </div>
                    <% if (usuario.rol === 'admin') { %>
                    <div class="d-flex gap-2 ms-3">
                        <a href="/anuncios/<%= a.id %>/editar" class="btn-editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form action="/anuncios/<%= a.id %>/eliminar" method="POST"
                              onsubmit="return confirm('¿Seguro que quieres eliminar este anuncio?')">
                            <button type="submit" class="btn-eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }) %>
        <% } %>

    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
