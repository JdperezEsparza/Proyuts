<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: anuncio ? 'Editar Anuncio' : 'Nuevo Anuncio' }) %>
    <style>
        :root {
            --verde-uts: #C3D730;
            --verde-uts-suave: #F0F5CC;
            --verde-uts-oscuro: #7A8A00;
            --gris-claro: #B3B3B3;
            --gris-medio: #878787;
            --fondo: #F5F5F5;
            --oscuro: #1A1A1A;
        }

        body { background-color: var(--fondo); }

        /* === BOTÓN VOLVER === */
        .btn-volver {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 10px;
            padding: 4px 12px;
            font-size: 0.9rem;
            transition: border-color 0.2s, color 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        .btn-volver:hover { border-color: var(--oscuro); color: var(--oscuro); }

        /* === CARD === */
        .card-form {
            border: 1px solid #E5E5E5 !important;
            border-radius: 16px;
            background: #fff;
        }

        /* === INPUTS === */
        .form-control:focus,
        .form-select:focus {
            border-color: var(--verde-uts);
            box-shadow: 0 0 0 3px rgba(195, 215, 48, 0.2);
        }

        /* === BOTÓN PUBLICAR / GUARDAR === */
        .btn-uts {
            background: var(--verde-uts);
            color: var(--oscuro);
            font-weight: 700;
            border: none;
            border-radius: 10px;
            padding: 8px 24px;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background 0.2s;
            cursor: pointer;
        }
        .btn-uts:hover { background: #b0c228; color: var(--oscuro); }

        /* === BOTÓN CANCELAR === */
        .btn-cancelar {
            background: transparent;
            border: 1px solid var(--gris-medio);
            color: var(--gris-medio);
            border-radius: 10px;
            padding: 8px 24px;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: border-color 0.2s, color 0.2s;
        }
        .btn-cancelar:hover { border-color: var(--oscuro); color: var(--oscuro); }

        /* === ALERTA ERROR === */
        .alerta-error {
            background: #FFEBEE;
            border: 1px solid #E53935;
            color: #B71C1C;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }

        /* === ÍCONO TÍTULO === */
        .icon-titulo { color: var(--verde-uts-oscuro); }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-md-7">

                <div class="d-flex align-items-center mb-4">
                    <a href="/anuncios" class="btn-volver me-3"><i class="bi bi-arrow-left"></i></a>
                    <h4 class="fw-bold mb-0">
                        <i class="bi bi-megaphone me-2 icon-titulo"></i>
                        <%= anuncio ? 'Editar anuncio' : 'Nuevo anuncio' %>
                    </h4>
                </div>

                <div class="card-form card p-4">
                    <% if (error) { %>
                    <div class="alerta-error">
                        <i class="bi bi-exclamation-circle me-2"></i><%= error %>
                    </div>
                    <% } %>

                    <form action="<%= anuncio ? '/anuncios/' + anuncio.id + '/editar' : '/anuncios' %>" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Título <span class="text-danger">*</span></label>
                            <input type="text" name="titulo" class="form-control"
                                   placeholder="Título del anuncio"
                                   value="<%= anuncio ? anuncio.titulo : '' %>" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Contenido <span class="text-danger">*</span></label>
                            <textarea name="contenido" class="form-control" rows="6"
                                      placeholder="Escribe el contenido del anuncio..."
                                      required><%= anuncio ? anuncio.contenido : '' %></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-uts">
                                <i class="bi bi-<%= anuncio ? 'check-circle' : 'plus-circle' %>"></i>
                                <%= anuncio ? 'Guardar cambios' : 'Publicar anuncio' %>
                            </button>
                            <a href="/anuncios" class="btn-cancelar">Cancelar</a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
</body>
</html>
