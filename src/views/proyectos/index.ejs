
<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', { titulo: 'Mis Proyectos' }) %>
    <style>
        .stat-card { border-radius: 16px; border: none; box-shadow: var(--shadow); }
        .proyecto-card {
            border: none;
            border-radius: 12px;
            box-shadow: var(--shadow);
            transition: transform 0.2s;
        }
        .proyecto-card:hover { transform: translateY(-3px); }
        .proyecto-card.terminado   { border-left: 5px solid #2e7d32; }
        .proyecto-card.en_progreso { border-left: 5px solid #e65100; }
        .proyecto-card.enviado     { border-left: 5px solid #1a237e; }
        .proyecto-card.rechazado   { border-left: 5px solid #c62828; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container py-4">

        <!-- Encabezado -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center">
                <a href="/dashboard" class="btn btn-outline-secondary btn-sm me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h4 class="fw-bold mb-0">
                    <i class="bi bi-folder2-open me-2 text-primary"></i>Mis Proyectos
                </h4>
            </div>
            <a href="/proyectos/nuevo" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Nuevo proyecto
            </a>
        </div>

        <!-- Tarjetas de resumen -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="stat-card card p-3 text-center">
                    <h2 class="fw-bold text-primary mb-0"><%= total %></h2>
                    <small class="text-muted">Total proyectos</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card card p-3 text-center">
                    <h2 class="fw-bold text-success mb-0"><%= terminados %></h2>
                    <small class="text-muted">Aprobados</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card card p-3 text-center">
                    <h2 class="fw-bold text-warning mb-0"><%= total - terminados %></h2>
                    <small class="text-muted">En progreso</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card card p-3 text-center">
                    <h2 class="fw-bold text-danger mb-0"><%= faltan %></h2>
                    <small class="text-muted">Faltan para graduarse</small>
                </div>
            </div>
        </div>

        <!-- Barra de progreso -->
        <div class="card p-3 mb-4" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
            <div class="d-flex justify-content-between mb-1">
                <small class="fw-bold">Progreso hacia la graduación</small>
                <small class="text-muted"><%= terminados %> / 52 proyectos aprobados</small>
            </div>
            <div class="progress" style="height:12px; border-radius:8px;">
                <div class="progress-bar bg-success" role="progressbar"
                     style="width:<%= Math.min(100,(terminados/52)*100) %>%; border-radius:8px;">
                </div>
            </div>
            <small class="text-muted mt-1"><%= Math.round((terminados/52)*100) %>% completado</small>
        </div>

        <!-- Filtros -->
        <div class="d-flex gap-2 mb-3 flex-wrap">
            <button class="btn btn-sm btn-primary" onclick="filtrar('todos')">Todos</button>
            <button class="btn btn-sm btn-outline-success" onclick="filtrar('terminado')">Aprobados</button>
            <button class="btn btn-sm btn-outline-primary" onclick="filtrar('enviado')">Enviados</button>
            <button class="btn btn-sm btn-outline-danger" onclick="filtrar('rechazado')">Rechazados</button>
            <button class="btn btn-sm btn-outline-warning" onclick="filtrar('en_progreso')">En progreso</button>
        </div>

        <!-- Lista de proyectos -->
        <% if (proyectos.length === 0) { %>
        <div class="card p-5 text-center" style="border:none; border-radius:16px; box-shadow:var(--shadow);">
            <i class="bi bi-folder2-open fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">Aún no tienes proyectos registrados</h5>
            <a href="/proyectos/nuevo" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle me-1"></i>Registrar mi primer proyecto
            </a>
        </div>
        <% } else { %>
        <div id="lista-proyectos">
            <% proyectos.forEach(p => { %>
            <div class="proyecto-card card p-3 mb-3 <%= p.estado %>" data-estado="<%= p.estado %>">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">

                        <!-- Título y badge de estado -->
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <h6 class="fw-bold mb-0"><%= p.titulo %></h6>
                            <span class="badge
                                <%= p.estado === 'terminado'  ? 'bg-success' :
                                   p.estado === 'enviado'    ? 'bg-primary'  :
                                   p.estado === 'rechazado'  ? 'bg-danger'   :
                                   'bg-warning text-dark' %>">
                                <%= p.estado === 'terminado'  ? 'Aprobado'              :
                                   p.estado === 'enviado'    ? 'Enviado para revisión'  :
                                   p.estado === 'rechazado'  ? 'Rechazado'              :
                                   'En progreso' %>
                            </span>
                        </div>

                        <!-- Descripción -->
                        <% if (p.descripcion) { %>
                        <p class="text-muted small mb-1"><%= p.descripcion %></p>
                        <% } %>

                        <!-- Info -->
                        <div class="d-flex gap-3 mt-1 flex-wrap">
                            <small class="text-muted">
                                <i class="bi bi-book me-1"></i><%= p.nombreCurso || 'Sin curso' %>
                            </small>
                            <small class="text-muted">
                                <i class="bi bi-calendar me-1"></i>
                                <%= new Date(p.fechaRealizacion).toLocaleDateString('es-CO') %>
                            </small>
                            <small class="text-muted">
                                <i class="bi bi-bookmark me-1"></i>Semestre <%= p.semestre %>
                            </small>
                        </div>

                        <!-- Motivo de rechazo (visible solo para el estudiante) -->
                        <% if (p.estado === 'rechazado' && p.comentarioProfesor) { %>
                        <div class="alert alert-danger py-2 px-3 mt-2 mb-0 small">
                            <i class="bi bi-x-circle me-1"></i>
                            <strong>Motivo del rechazo:</strong> <%= p.comentarioProfesor %>
                            <br>
                            <small class="opacity-75">Puedes editar tu proyecto y enviarlo nuevamente para revisión.</small>
                        </div>
                        <% } %>

                        <!-- Mensaje si está aprobado -->
                        <% if (p.estado === 'terminado') { %>
                        <div class="alert alert-success py-2 px-3 mt-2 mb-0 small">
                            <i class="bi bi-check-circle me-1"></i>
                            Este proyecto fue <strong>aprobado</strong> por el profesor y cuenta para tu graduación.
                        </div>
                        <% } %>

                        <!-- Mensaje si está enviado -->
                        <% if (p.estado === 'enviado') { %>
                        <div class="alert alert-info py-2 px-3 mt-2 mb-0 small">
                            <i class="bi bi-hourglass-split me-1"></i>
                            Este proyecto está <strong>en espera de revisión</strong> por el profesor.
                        </div>
                        <% } %>

                    </div>

                    <!-- Botones de acción -->
                    <div class="d-flex gap-2 ms-3">
                        <!-- Solo se puede editar si no está aprobado -->
                        <% if (p.estado !== 'terminado') { %>
                        <a href="/proyectos/<%= p.id %>/editar" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form action="/proyectos/<%= p.id %>/eliminar" method="POST"
                              onsubmit="return confirm('¿Seguro que quieres eliminar este proyecto?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
        <% } %>

    </div>
    <%- include('../partials/scripts') %>
    <script>
        function filtrar(estado) {
            document.querySelectorAll('[data-estado]').forEach(t => {
                t.style.display = (estado === 'todos' || t.dataset.estado === estado) ? 'block' : 'none';
            });
        }
    </script>
</body>
</html>
